#!/usr/bin/env bash
# forge-deploy — Operator-driven deploy CLI for the forge Pi.
#
# Pulls images from ghcr.io/armoryworks/forge-{server,ui,test},
# pins the operative .env to the chosen tag, and runs the standard
# docker compose flow with healthcheck-gated rollback.
#
# Source of truth: see e:/dev/forge/docs/cicd-design.md (Phases 3+4).
#
# Bash conventions:
#   - set -euo pipefail
#   - all variables quoted
#   - [[ ]] over [ ]
#   - trap-based cleanup
#   - never deploys 'latest' (humans use floating tags, deployments use immutable)
#
# Public domain commands — see usage() below.

set -euo pipefail

# ─────────────────────────────────────────────────────────────
# Constants
# ─────────────────────────────────────────────────────────────

readonly FORGE_DEPLOY_VERSION="0.6.1"
readonly REPO_ROOT="${FORGE_DEPLOY_REPO:-/opt/forge-deploy}"
readonly STATE_DIR="/etc/forge"
readonly STATE_FILE="${STATE_DIR}/deploy-state.json"
readonly LOG_FILE="/var/log/forge-deploy.log"
readonly ENV_FILE="${REPO_ROOT}/.env"
readonly COMPOSE_BASE="${REPO_ROOT}/docker-compose.yml"
readonly COMPOSE_PROD="${REPO_ROOT}/docker-compose.prod.yml"
readonly COMPOSE_COHOST="${REPO_ROOT}/docker-compose.cohost.yml"
readonly REGISTRY_HOST="ghcr.io"
readonly REGISTRY_OWNER="armoryworks"
# Max seconds to wait for a service to report healthy before rolling back.
# forge-api runs EF Core migrations + warms its composite health check
# (Postgres, Hangfire, MinIO, SignalR all gate /api/v1/health) BEFORE the
# endpoint returns 200, so on a populated database a clean deploy routinely
# needs more than the original fixed 60s — and a premature rollback is risky
# because the new schema may already be migrated. Override per host via .env
# (HEALTHCHECK_TIMEOUT_SECS=...) or a shell env var; default 180.
readonly HEALTHCHECK_TIMEOUT_DEFAULT=180
readonly HEALTHCHECK_POLL_INTERVAL=2

# Service descriptors: service_id|compose_service|image_repo|env_var|healthcheck_kind
# healthcheck_kind: docker (use container healthcheck) or http:<path> (curl from host)
readonly SERVICES=(
  "api|forge-api|forge-api|SERVER_IMAGE_TAG|http:/api/v1/health"
  "ui|forge-ui|forge-ui|UI_IMAGE_TAG|docker"
  "test|forge-test|forge-test|TEST_IMAGE_TAG|docker"
  "demo|forge-demo|forge-demo|DEMO_IMAGE_TAG|docker"
)

# Full stack roster for the component wizard: compose_service|group|svc_id|label
#   group:  backend (api + its data tier) | frontend | test | optional
#   svc_id: the forge-deploy versioned id (api|ui|test) or "-" if not versioned
# container_name in the compose files equals the service name, so detection by
# `docker ps` name match is exact.
readonly STACK_SERVICES=(
  "forge-api|backend|api|API — .NET backend"
  "forge|backend|-|Database — Postgres/pgvector"
  "forge-storage|backend|-|Object storage — MinIO"
  "forge-backup|backend|-|DB backup sidecar"
  "forge-ui|frontend|ui|Web UI — Angular/nginx"
  "forge-demo|frontend|demo|Public demo SPA [profile: demo]"
  "forge-test|test|test|Public test/demo SPA [profile: test]"
  "forge-ai|optional|-|AI — Ollama [profile: ai]"
  "forge-ai-init|optional|-|AI model init [profile: ai]"
  "forge-tts|optional|-|Text-to-speech [profile: tts]"
  "forge-logs|optional|-|Logs/Seq [profile: logs]"
  "forge-signing|optional|-|DocuSeal signing [profile: signing]"
)
readonly COMPOSE_SCOPE="${REPO_ROOT}/docker-compose.scope.yml"
# Remote-API wiring (UI-only box): a tiny nginx forwarder on the `forge-api`
# network alias relays forge-ui's baked /api + /hubs proxy to the real API on
# another server, so the image needs no rebuild.
readonly COMPOSE_REMOTE_API="${REPO_ROOT}/docker-compose.remote-api.yml"
readonly REMOTE_API_CONF="${REPO_ROOT}/forge-api-proxy.conf"

# Tag format regexes
readonly TAG_RE_SHA='^main-[a-f0-9]{7}$'
readonly TAG_RE_SEMVER='^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.]+)?$'

# ─────────────────────────────────────────────────────────────
# Color output (respects NO_COLOR)
# ─────────────────────────────────────────────────────────────

if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
  C_RESET=""; C_DIM=""; C_RED=""; C_GREEN=""; C_YELLOW=""; C_CYAN=""; C_BOLD=""
else
  C_RESET=$'\033[0m'
  C_DIM=$'\033[2m'
  C_RED=$'\033[31m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_CYAN=$'\033[36m'
  C_BOLD=$'\033[1m'
fi

# Mutable option globals — set by argument parsing, read by cmd_setup / cmd_edge.
SETUP_ROLE=""; SETUP_API_URL=""; SETUP_DB_HOST=""; SETUP_MINIO=""
EDGE_HOST=""; EDGE_UI=""; EDGE_API=""; EDGE_CERT=""; EDGE_KEY=""; EDGE_NO_RELOAD=""

step() { printf '%s==> %s%s\n' "${C_CYAN}" "$1" "${C_RESET}"; }
ok()   { printf '    %s[OK]%s %s\n' "${C_GREEN}" "${C_RESET}" "$1"; }
warn() { printf '    %s[!!]%s %s\n' "${C_YELLOW}" "${C_RESET}" "$1"; }
err()  { printf '    %s[XX]%s %s\n' "${C_RED}" "${C_RESET}" "$1" >&2; }
die()  { err "$1"; exit "${2:-1}"; }

# ─────────────────────────────────────────────────────────────
# Usage
# ─────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
forge-deploy ${FORGE_DEPLOY_VERSION} — forge deploy CLI

USAGE:
  forge-deploy --setup                Topology wizard: pick this box's role + auto-wire everything
  forge-deploy --setup --role <r>     Unattended setup (r = all|ui+api|api+db|ui|api|db)
                                        flags: --api-url <u> --db-host <h[:port]> --minio <h[:port]>
                                               --host <fqdn> --cert <p> --key <p>  (edge vhost)
  forge-deploy                        No args: first run -> setup wizard; configured box -> pick a
                                      version per component (Enter keeps current, r=re-setup, q=quit)
  forge-deploy <tag>                  Deploy a specific tag to this box's components (or --service)
  forge-deploy <tag> --allow-destructive  Pre-approve destructive schema changes during reconcile
                                      (skips the halt+enumerate; only with ENABLE_SCHEMA_RECONCILE=true)
  forge-deploy --service <name>       Narrow to one service (api | ui | test | demo | all) — scoped to this box
  forge-deploy --components [list]    Show / set this box's components (e.g. --components "ui")
  forge-deploy --wizard               Interactive: REMOVE installed components from this box
                                      (stops+deletes containers, prevents auto-recreate; no start)
  forge-deploy --up                   Bring up ONLY this box's components (never recreates removed ones)
  forge-deploy compose <args>         Scope-aware 'docker compose' passthrough (use instead of bare compose)
  forge-deploy --remote-api <url>     UI box: forward /api + /hubs to the API box (no image rebuild)
                                      (no arg = show; 'off' = remove the wiring)
  forge-deploy --remote-db <h[:port]> API box: point forge-api at a remote Postgres (+ --minio <h>)
                                      (no arg = show; 'off' = revert to local db)
  forge-deploy --edge --host <fqdn>   Generate + install the host nginx vhost (SPA->ui, api->API box)
                                      flags: --ui <t> --api <t> --cert <p> --key <p> --no-reload
  forge-deploy --list                 List recent versions paired with their build-sha (this box only)
  forge-deploy --list --releases      List <X.Y.Z> semver tags only
  forge-deploy --list --builds        List main-<sha> build tags only
  forge-deploy --status               Show currently deployed SHA and container health (this box only)
  forge-deploy --rollback             Re-pin to the previously deployed tag
  forge-deploy --logs                 Tail the deploy history log
  forge-deploy --self-update          git pull forge-deploy + reinstall
  forge-deploy --recover              Doctor: detect common failure modes / an incomplete
                                      setup, then fix-and-resume in place (keeps your data)
  forge-deploy --fresh-start          Wipe EVERYTHING on this box (containers, database,
                                      files, config) after typed confirmation, then set up
                                      from scratch
  forge-deploy --help                 This usage

EXAMPLES:
  forge-deploy main-abc1234                       Deploy that SHA to all services
  forge-deploy main-abc1234 --service api         Deploy that SHA only to api
  forge-deploy --service ui                       Pick a tag interactively for ui only
  forge-deploy 1.2.3                              Deploy a semver release to all

NOTES:
  * Bring the box up with 'forge-deploy --up', NOT bare 'docker compose up'.
    Bare compose starts every service in the file set and resurrects the
    components you removed with --wizard. --up brings up only this box's
    components; 'forge-deploy compose ...' wraps any other compose verb with
    the correct -f set + per-box scope.
  * Component scope: this box only lists/deploys the services named in
    FORGE_DEPLOY_SERVICES (.env) — e.g. "ui" on a UI box, "api" on an API
    box. Unset = all (legacy all-in-one). Set it with --components, e.g.
    'forge-deploy --components "ui"'. The API and DB on a separate box are
    invisible to a UI box's tooling once scoped.
  * Default --list pairs each X.Y.Z version with its main-<sha> build tag
    (they share a manifest digest). Use --releases / --builds for a single
    fast column. For private packages, export GHCR_USER + GHCR_TOKEN or let
    install-forge-deploy.sh store them in ${STATE_DIR}.
  * Refuses to deploy 'latest' — only immutable tags are accepted.
  * State: ${STATE_FILE}
  * Log:   ${LOG_FILE}
  * Compose files: ${COMPOSE_BASE} + ${COMPOSE_PROD}
EOF
}

# ─────────────────────────────────────────────────────────────
# Service descriptor helpers
# ─────────────────────────────────────────────────────────────

service_field() {
  # service_field <service_id> <field_index 1..5>
  local id="$1" idx="$2" entry
  for entry in "${SERVICES[@]}"; do
    if [[ "${entry%%|*}" == "$id" ]]; then
      IFS='|' read -r _f1 _f2 _f3 _f4 _f5 <<<"$entry"
      case "$idx" in
        1) printf '%s\n' "$_f1" ;;
        2) printf '%s\n' "$_f2" ;;
        3) printf '%s\n' "$_f3" ;;
        4) printf '%s\n' "$_f4" ;;
        5) printf '%s\n' "$_f5" ;;
        *) return 1 ;;
      esac
      return 0
    fi
  done
  return 1
}

service_compose() { service_field "$1" 2; }
service_repo()    { service_field "$1" 3; }
service_envvar()  { service_field "$1" 4; }
service_health()  { service_field "$1" 5; }

all_service_ids() {
  local entry
  for entry in "${SERVICES[@]}"; do
    printf '%s\n' "${entry%%|*}"
  done
}

# Which versioned services THIS box deploys. Declared in .env as
# FORGE_DEPLOY_SERVICES (space/comma list of api|ui|test). Unset = all
# (legacy all-in-one behavior). This is the per-box component scope: it's
# what makes the UI box list/deploy only forge-ui and the API box only
# forge-api — instead of every box surfacing all three regardless of role.
box_service_ids() {
  local raw
  raw=$(env_get FORGE_DEPLOY_SERVICES 2>/dev/null | tr ',' ' ' | tr -s '[:space:]' ' ')
  raw="${raw#"${raw%%[![:space:]]*}"}"   # ltrim
  raw="${raw%"${raw##*[![:space:]]}"}"   # rtrim
  if [[ -z "$raw" ]]; then
    all_service_ids
    return
  fi
  # Emit known ids in SERVICES order, intersected with the declared list.
  local id want
  for id in $(all_service_ids); do
    for want in $raw; do
      [[ "$id" == "$want" ]] && { printf '%s\n' "$id"; break; }
    done
  done
}

# Is a compose service scoped out on this box? (reads FORGE_SCOPED_OUT)
is_scoped_out() {
  local s="$1"
  printf '%s\n' $(env_get FORGE_SCOPED_OUT 2>/dev/null | tr ',' ' ') | grep -qx "$s"
}

# Pretty one-line scope summary for headers.
box_scope_label() {
  local declared ids
  declared=$(env_get FORGE_DEPLOY_SERVICES 2>/dev/null | tr ',' ' ' | tr -s '[:space:]' ' ' | sed 's/^ //;s/ $//')
  ids=$(box_service_ids | tr '\n' ' ' | sed 's/ $//')
  if [[ -z "$declared" ]]; then
    printf '%s (all — FORGE_DEPLOY_SERVICES not set)' "$ids"
  else
    printf '%s' "$ids"
  fi
}

# ─────────────────────────────────────────────────────────────
# Pre-flight
# ─────────────────────────────────────────────────────────────

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1 (run scripts/install-forge-deploy.sh)"
}

# Probe TCP reachability of host:port with a short timeout, using whatever
# portable tool exists (nc, else `timeout`+bash /dev/tcp, else bare /dev/tcp).
# Returns 0 reachable, 1 unreachable. The caller (check_remote_reachable) is
# responsible for the no-probe-tool degradation so it never hard-blocks.
tcp_reachable() {
  local host="$1" port="$2" timeout_s="${3:-4}"
  if command -v nc >/dev/null 2>&1; then
    nc -z -w "$timeout_s" "$host" "$port" >/dev/null 2>&1 && return 0 || return 1
  fi
  # bash /dev/tcp — wrap in `timeout` when available so a black-holed host can't
  # hang the deploy; without `timeout`, the connect still fails fast on refusal.
  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout_s" bash -c ": >/dev/tcp/${host}/${port}" >/dev/null 2>&1 && return 0 || return 1
  fi
  ( : >"/dev/tcp/${host}/${port}" ) >/dev/null 2>&1 && return 0
  # Distinguish "connect failed" from "/dev/tcp unsupported": if the shell has
  # /dev/tcp support a refusal is a real 1; assume support on bash and report 1.
  return 1
}

# Pre-deploy reachability gate for split topology. Verifies the remote Postgres
# (and MinIO endpoint, if given) accept TCP before we pull/recreate anything.
# Best-effort: if no probe tool exists we warn and continue. Local DB (host
# unset/empty/'forge') is a no-op so single-box/api+db paths are untouched.
#   check_remote_reachable [db_host] [db_port] [minio_endpoint]
# With no args it reads DB_HOST/DB_PORT/MINIO_ENDPOINT from .env.
check_remote_reachable() {
  local dbh="${1:-}" dbp="${2:-}" minio="${3:-}"
  [[ -n "$dbh" ]] || dbh=$(env_get DB_HOST | tr -d '[:space:]')
  [[ -n "$dbp" ]] || dbp=$(env_get DB_PORT | tr -d '[:space:]')
  [[ -n "$minio" ]] || minio=$(env_get MINIO_ENDPOINT | tr -d '[:space:]')

  # Local DB (or unset) — nothing remote to probe.
  [[ -n "$dbh" && "$dbh" != "forge" ]] || return 0
  dbp="${dbp:-5432}"

  if ! command -v nc >/dev/null 2>&1 && ! command -v timeout >/dev/null 2>&1; then
    warn "No nc/timeout to probe ${dbh}:${dbp} — skipping reachability check (continuing)"
    return 0
  fi

  local rc=0
  step "Checking remote reachability before deploy"
  if tcp_reachable "$dbh" "$dbp"; then
    ok "Postgres ${dbh}:${dbp} reachable"
  else
    err "Postgres ${dbh}:${dbp} not reachable (is the db box up + LAN-published?)"
    rc=1
  fi

  # Only probe MinIO when it's a real remote endpoint (not the local default).
  if [[ -n "$minio" && "$minio" != forge-storage:* ]]; then
    local mh mp
    mh="${minio%%:*}"; mp="${minio##*:}"; [[ "$mp" == "$minio" ]] && mp="9000"
    if tcp_reachable "$mh" "$mp"; then
      ok "MinIO ${mh}:${mp} reachable"
    else
      err "MinIO ${mh}:${mp} not reachable (is MinIO up + LAN-published on the db box?)"
      rc=1
    fi
  fi
  return "$rc"
}

preflight() {
  require_cmd docker
  require_cmd curl
  require_cmd jq
  docker compose version >/dev/null 2>&1 || die "docker compose plugin missing"

  if [[ ! -f "$COMPOSE_BASE" ]]; then
    die "Base compose file not found: $COMPOSE_BASE (set FORGE_DEPLOY_REPO?)"
  fi
  if [[ ! -f "$COMPOSE_PROD" ]]; then
    die "Prod compose overlay not found: $COMPOSE_PROD"
  fi
  if [[ "$(env_get QBE_HOSTING_MODE 2>/dev/null | tr -d '[:space:]')" == "cohost" ]] && [[ ! -f "$COMPOSE_COHOST" ]]; then
    die "Cohost mode (QBE_HOSTING_MODE=cohost) but overlay not found: $COMPOSE_COHOST"
  fi
  if [[ ! -f "$ENV_FILE" ]]; then
    die "Env file not found: $ENV_FILE (run setup.sh first)"
  fi
  if [[ ! -f "$STATE_FILE" ]]; then
    die "State file not found: $STATE_FILE (run scripts/install-forge-deploy.sh)"
  fi
  if [[ ! -w "$STATE_FILE" ]]; then
    die "State file not writable: $STATE_FILE"
  fi
  if [[ ! -w "$LOG_FILE" ]]; then
    die "Log file not writable: $LOG_FILE"
  fi
}

# ─────────────────────────────────────────────────────────────
# Tag validation
# ─────────────────────────────────────────────────────────────

validate_tag() {
  local tag="$1"
  if [[ "$tag" == "latest" ]]; then
    die "Refusing to deploy 'latest' — pass a main-<sha> or <X.Y.Z> tag (try: forge-deploy --list)"
  fi
  if [[ ! "$tag" =~ $TAG_RE_SHA ]] && [[ ! "$tag" =~ $TAG_RE_SEMVER ]]; then
    die "Invalid tag format: '$tag' (expected main-<7-hex> or X.Y.Z)"
  fi
}

# ─────────────────────────────────────────────────────────────
# GHCR API
# ─────────────────────────────────────────────────────────────

# Per-repo token cache. GHCR pull tokens live ~5 min — plenty for one
# command run, and caching means the per-tag digest resolution in the
# combined list view doesn't re-fetch a token for every single HEAD.
declare -A _GHCR_TOKEN_CACHE

# Bearer token for a GHCR image. Works anonymously for public images;
# when GHCR_USER + GHCR_TOKEN are exported (or stored in the state dir)
# the token is requested with Basic auth so private packages resolve too.
ghcr_token() {
  local repo="$1"
  if [[ -n "${_GHCR_TOKEN_CACHE[$repo]:-}" ]]; then
    printf '%s' "${_GHCR_TOKEN_CACHE[$repo]}"
    return 0
  fi
  local url="https://${REGISTRY_HOST}/token?service=${REGISTRY_HOST}&scope=repository:${REGISTRY_OWNER}/${repo}:pull"
  local token creds
  creds=$(ghcr_basic_creds)
  if [[ -n "$creds" ]]; then
    token=$(curl -fsSL -u "$creds" "$url" | jq -r '.token' 2>/dev/null || true)
  else
    token=$(curl -fsSL "$url" | jq -r '.token' 2>/dev/null || true)
  fi
  [[ -n "$token" && "$token" != "null" ]] || return 1
  _GHCR_TOKEN_CACHE[$repo]="$token"
  printf '%s' "$token"
}

# Optional Basic-auth credentials for private packages. Reads GHCR_USER +
# GHCR_TOKEN from the environment first, then from the state dir files
# (written by install-forge-deploy.sh). Echoes "user:token" or nothing.
ghcr_basic_creds() {
  if [[ -n "${GHCR_USER:-}" && -n "${GHCR_TOKEN:-}" ]]; then
    printf '%s:%s' "$GHCR_USER" "$GHCR_TOKEN"
    return 0
  fi
  local uf="${STATE_DIR}/ghcr-user" tf="${STATE_DIR}/ghcr-token"
  if [[ -r "$uf" && -r "$tf" ]]; then
    local u t
    u=$(tr -d '\n\r' < "$uf"); t=$(tr -d '\n\r' < "$tf")
    [[ -n "$u" && -n "$t" ]] && printf '%s:%s' "$u" "$t"
  fi
}

# List tags for a given image, following GHCR pagination so images with
# 100+ tags (every build accumulates one) aren't truncated to the first
# page. Returns one tag per line. Empty if none.
ghcr_list_tags() {
  local repo="$1" token page last="" all="" n=100
  token=$(ghcr_token "$repo") || return 1
  [[ -n "$token" ]] || return 1
  while :; do
    local url="https://${REGISTRY_HOST}/v2/${REGISTRY_OWNER}/${repo}/tags/list?n=${n}"
    [[ -n "$last" ]] && url="${url}&last=${last}"
    page=$(curl -fsSL \
      -H "Authorization: Bearer $token" \
      -H "Accept: application/vnd.oci.image.index.v1+json" \
      "$url" | jq -r '.tags[]?' 2>/dev/null || true)
    [[ -z "$page" ]] && break
    all+="${page}"$'\n'
    local count
    count=$(printf '%s\n' "$page" | grep -c . || true)
    (( count < n )) && break
    last=$(printf '%s\n' "$page" | tail -1)
  done
  printf '%s' "$all" | grep -v '^$' || true
}

# Echo the manifest digest for a tag (the sha256:… that buildx assigns the
# manifest list). Tags pushed together by `imagetools create` share one
# digest, so this is how the list view pairs a version with its build-sha.
# Exported so it can run under `xargs -P` for parallel resolution.
ghcr_manifest_digest() {
  local repo="$1" tag="$2" token
  token=$(ghcr_token "$repo") || return 1
  [[ -n "$token" ]] || return 1
  curl -fsSL -I \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.oci.image.index.v1+json" \
    -H "Accept: application/vnd.docker.distribution.manifest.list.v2+json" \
    -H "Accept: application/vnd.oci.image.manifest.v1+json" \
    -H "Accept: application/vnd.docker.distribution.manifest.v2+json" \
    "https://${REGISTRY_HOST}/v2/${REGISTRY_OWNER}/${repo}/manifests/${tag}" 2>/dev/null \
    | tr -d '\r' \
    | awk -F': ' 'tolower($1)=="docker-content-digest"{print $2}' \
    | tail -1
}

# HEAD a tag's manifest to verify existence. 0 = exists, 1 = missing.
ghcr_tag_exists() {
  local repo="$1" tag="$2" token http_code
  token=$(ghcr_token "$repo") || return 1
  [[ -n "$token" ]] || return 1
  http_code=$(curl -s -o /dev/null -w '%{http_code}' \
    -H "Authorization: Bearer $token" \
    -H "Accept: application/vnd.docker.distribution.manifest.v2+json" \
    -H "Accept: application/vnd.oci.image.manifest.v1+json" \
    -H "Accept: application/vnd.oci.image.index.v1+json" \
    -H "Accept: application/vnd.docker.distribution.manifest.list.v2+json" \
    "https://${REGISTRY_HOST}/v2/${REGISTRY_OWNER}/${repo}/manifests/${tag}" \
    -X HEAD)
  [[ "$http_code" == "200" ]]
}

# ─────────────────────────────────────────────────────────────
# State file management
# ─────────────────────────────────────────────────────────────

state_get() {
  # state_get <repo>           -> JSON object for that image (or null)
  # state_get <repo> <field>   -> string field
  local repo="$1" field="${2:-}"
  if [[ -z "$field" ]]; then
    jq -r --arg r "$repo" '.[$r] // {} | tojson' "$STATE_FILE"
  else
    jq -r --arg r "$repo" --arg f "$field" '.[$r][$f] // ""' "$STATE_FILE"
  fi
}

state_set() {
  # state_set <repo> <new-current-tag>
  # Updates: prior <- current, current <- new, deployedAt <- now
  local repo="$1" new_tag="$2" now tmp prior_tag
  now=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
  prior_tag=$(state_get "$repo" current)
  tmp=$(mktemp)
  jq --arg r "$repo" --arg cur "$new_tag" --arg prior "$prior_tag" --arg ts "$now" \
    '.[$r] = {current: $cur, prior: $prior, deployedAt: $ts}' \
    "$STATE_FILE" > "$tmp"
  mv "$tmp" "$STATE_FILE"
  chmod 0640 "$STATE_FILE" 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────────
# .env helpers
# ─────────────────────────────────────────────────────────────

env_get() {
  local key="$1"
  if grep -qE "^${key}=" "$ENV_FILE" 2>/dev/null; then
    grep -E "^${key}=" "$ENV_FILE" | head -1 | cut -d= -f2-
  fi
}

env_set() {
  local key="$1" val="$2" tmp
  tmp=$(mktemp)
  if grep -qE "^${key}=" "$ENV_FILE"; then
    # Preserve other lines verbatim; rewrite this one with awk to avoid sed escaping issues.
    awk -v k="$key" -v v="$val" '
      BEGIN { FS=OFS="=" }
      $1==k { print k "=" v; next }
      { print }
    ' "$ENV_FILE" > "$tmp"
  else
    cp "$ENV_FILE" "$tmp"
    printf '%s=%s\n' "$key" "$val" >> "$tmp"
  fi
  mv "$tmp" "$ENV_FILE"
}

# Effective healthcheck timeout (seconds): .env override > shell env > default.
# Validates to a positive integer; falls back to the default on garbage so a
# typo can never make the wait loop exit immediately and roll back a good build.
health_timeout() {
  local v
  v=$(env_get HEALTHCHECK_TIMEOUT_SECS)
  v="${v:-${HEALTHCHECK_TIMEOUT_SECS:-$HEALTHCHECK_TIMEOUT_DEFAULT}}"
  [[ "$v" =~ ^[1-9][0-9]*$ ]] || v="$HEALTHCHECK_TIMEOUT_DEFAULT"
  printf '%s' "$v"
}

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

log_event() {
  # log_event <service> <from> <to> <outcome>
  local svc="$1" from="$2" to="$3" outcome="$4" ts
  ts=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
  printf '%s %s %s -> %s %s\n' "$ts" "$svc" "${from:-<none>}" "$to" "$outcome" >> "$LOG_FILE"
}

# ─────────────────────────────────────────────────────────────
# Compose helpers
# ─────────────────────────────────────────────────────────────

compose() {
  local files=(-f "$COMPOSE_BASE") mode
  # In cohost mode the cohost overlay must sit BETWEEN base and prod (matches how
  # the stack is brought up: base,cohost,prod). Without it, deploys recreate
  # services without their cohost networking/port bindings. Standalone boxes are
  # unaffected (base+prod, exactly as before).
  mode=$(env_get QBE_HOSTING_MODE 2>/dev/null | tr -d '[:space:]')
  [[ "$mode" == "cohost" ]] && files+=(-f "$COMPOSE_COHOST")
  files+=(-f "$COMPOSE_PROD")
  # Remote-API forwarder (written by --remote-api): defines forge-api-proxy.
  [[ -f "$COMPOSE_REMOTE_API" ]] && files+=(-f "$COMPOSE_REMOTE_API")
  # Per-box scope override (written by --wizard): profiles-out services this
  # box must not run, so a bare `up` / --remove-orphans won't recreate them.
  # Last in the -f set so its profiles win.
  [[ -f "$COMPOSE_SCOPE" ]] && files+=(-f "$COMPOSE_SCOPE")
  docker compose --env-file "$ENV_FILE" "${files[@]}" "$@"
}

# Wait for a service to become healthy. Returns 0 healthy, 1 unhealthy/timeout.
wait_healthy() {
  local svc_id="$1" compose_svc health
  compose_svc=$(service_compose "$svc_id")
  health=$(service_health "$svc_id")
  local elapsed=0 timeout
  timeout=$(health_timeout)

  while (( elapsed < timeout )); do
    case "$health" in
      docker)
        # Use docker inspect on the container's Health.Status.
        local cid status
        cid=$(compose ps -q "$compose_svc" 2>/dev/null || true)
        if [[ -n "$cid" ]]; then
          status=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$cid" 2>/dev/null || echo unknown)
          if [[ "$status" == "healthy" ]]; then return 0; fi
          if [[ "$status" == "none" ]]; then
            # No healthcheck defined — fall back to "running" check.
            local running
            running=$(docker inspect --format '{{.State.Running}}' "$cid" 2>/dev/null || echo false)
            if [[ "$running" == "true" ]]; then
              # Give a brief settle time then accept.
              sleep 5
              return 0
            fi
          fi
        fi
        ;;
      http:*)
        local path="${health#http:}"
        # Hit the api healthcheck through the bound port (defaults from .env).
        local api_port
        api_port=$(env_get API_PORT || true)
        api_port="${api_port:-5000}"
        if curl -fsS --max-time 3 "http://127.0.0.1:${api_port}${path}" >/dev/null 2>&1; then
          return 0
        fi
        ;;
    esac
    sleep "$HEALTHCHECK_POLL_INTERVAL"
    elapsed=$(( elapsed + HEALTHCHECK_POLL_INTERVAL ))
  done
  return 1
}

# ─────────────────────────────────────────────────────────────
# Commands
# ─────────────────────────────────────────────────────────────

# Number of recent versions the combined view resolves + displays.
readonly LIST_VERSION_LIMIT=10

cmd_list() {
  local mode="${1:-combined}"  # combined | builds | releases
  local svc_id
  printf '\n%sAvailable tags%s (mode=%s)\n' "${C_BOLD}" "${C_RESET}" "$mode"
  printf '%sthis box: %s%s\n\n' "${C_DIM}" "$(box_scope_label)" "${C_RESET}"
  for svc_id in $(box_service_ids); do
    local repo
    repo=$(service_repo "$svc_id")
    printf '%s%s%s (%s)\n' "${C_CYAN}" "$repo" "${C_RESET}" "$svc_id"
    local tags
    tags=$(ghcr_list_tags "$repo" 2>/dev/null || true)
    if [[ -z "$tags" ]]; then
      printf '  %s(no tags found or image not yet published)%s\n' "${C_DIM}" "${C_RESET}"
      continue
    fi
    case "$mode" in
      builds)
        local matched
        # grep||true: under `set -e` a no-match grep would otherwise abort.
        matched=$(printf '%s\n' "$tags" | grep -E '^main-[a-f0-9]+$' | sort -r | head -"$LIST_VERSION_LIMIT" || true)
        [[ -z "$matched" ]] \
          && printf '  %s(no build tags)%s\n' "${C_DIM}" "${C_RESET}" \
          || printf '%s\n' "$matched" | sed 's/^/  /'
        ;;
      releases)
        local matched
        # sort -Vr: version-aware so 0.0.115 ranks above 0.0.9 (plain
        # sort -r would put 0.0.9 first — wrong). grep||true: see above.
        matched=$(printf '%s\n' "$tags" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.]+)?$' | sort -Vr | head -"$LIST_VERSION_LIMIT" || true)
        [[ -z "$matched" ]] \
          && printf '  %s(no release tags)%s\n' "${C_DIM}" "${C_RESET}" \
          || printf '%s\n' "$matched" | sed 's/^/  /'
        ;;
      combined|*)
        list_combined "$repo" "$tags"
        ;;
    esac
  done
  printf '\n'
}

# Combined view: pairs each recent X.Y.Z version with its main-<sha> build
# tag. The manifest workflow stitches both onto one digest, so we resolve
# the digest of every tag (in parallel) and group by it. Output:
#   0.0.115      (main-972e58a)   ← latest
list_combined() {
  local repo="$1" tags="$2"
  [[ -z "$tags" ]] && tags=$(ghcr_list_tags "$repo" 2>/dev/null || true)

  # grep||true throughout: under `set -e` a no-match grep aborts the run.
  local versions shas
  versions=$(printf '%s\n' "$tags" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.]+)?$' | sort -Vr | head -"$LIST_VERSION_LIMIT" || true)
  shas=$(printf '%s\n' "$tags" | grep -E '^main-[a-f0-9]+$' || true)

  if [[ -z "$versions" ]]; then
    # No semver tags yet — fall back to a plain build-hash list.
    local b
    b=$(printf '%s\n' "$shas" | sort -r | head -"$LIST_VERSION_LIMIT" || true)
    [[ -z "$b" ]] \
      && printf '  %s(no tags)%s\n' "${C_DIM}" "${C_RESET}" \
      || printf '%s\n' "$b" | sed 's/^/  /'
    return
  fi

  # Resolve digest → version for the shown versions, and the digest of every
  # build tag, in parallel. xargs -P keeps this responsive even with 100+
  # build tags. Token is pre-warmed so the parallel workers reuse the cache.
  ghcr_token "$repo" >/dev/null 2>&1 || true
  printf '  %s(resolving build hashes…)%s\r' "${C_DIM}" "${C_RESET}" >&2

  export REGISTRY_HOST REGISTRY_OWNER STATE_DIR
  export -f ghcr_manifest_digest ghcr_token ghcr_basic_creds

  local ver_digests sha_digests
  ver_digests=$(printf '%s\n' "$versions" \
    | xargs -P 8 -I{} bash -c 'd=$(ghcr_manifest_digest "$0" "$1"); [[ -n "$d" ]] && printf "%s\t%s\n" "$1" "$d"' "$repo" {} 2>/dev/null || true)
  sha_digests=$(printf '%s\n' "$shas" \
    | xargs -P 8 -I{} bash -c 'd=$(ghcr_manifest_digest "$0" "$1"); [[ -n "$d" ]] && printf "%s\t%s\n" "$1" "$d"' "$repo" {} 2>/dev/null || true)

  # digest → sha lookup.
  local -A sha_by_digest
  local tag dg
  while IFS=$'\t' read -r tag dg; do
    [[ -n "$dg" ]] && sha_by_digest["$dg"]="$tag"
  done <<<"$sha_digests"

  # version → digest lookup.
  local -A digest_by_ver
  while IFS=$'\t' read -r tag dg; do
    [[ -n "$tag" ]] && digest_by_ver["$tag"]="$dg"
  done <<<"$ver_digests"

  printf '  %-40s\r' '' >&2  # clear the progress line

  local first=1 v sha
  while IFS= read -r v; do
    [[ -z "$v" ]] && continue
    dg="${digest_by_ver[$v]:-}"
    sha="${sha_by_digest[$dg]:-}"
    local latest_note=""
    if [[ "$first" == "1" ]]; then latest_note="  ${C_DIM}← latest${C_RESET}"; first=0; fi
    if [[ -n "$sha" ]]; then
      printf '  %s%-12s%s  %s(%s)%s%s\n' "${C_BOLD}" "$v" "${C_RESET}" "${C_DIM}" "$sha" "${C_RESET}" "$latest_note"
    else
      printf '  %s%-12s%s  %s(build hash unresolved)%s%s\n' "${C_BOLD}" "$v" "${C_RESET}" "${C_DIM}" "${C_RESET}" "$latest_note"
    fi
  done <<<"$versions"
}

cmd_status() {
  printf '\n%sDeploy status%s\n' "${C_BOLD}" "${C_RESET}"
  printf '%sthis box: %s%s\n\n' "${C_DIM}" "$(box_scope_label)" "${C_RESET}"
  local svc_id
  for svc_id in $(box_service_ids); do
    local repo cur prior deployedAt compose_svc cid health_status
    repo=$(service_repo "$svc_id")
    compose_svc=$(service_compose "$svc_id")
    cur=$(state_get "$repo" current)
    prior=$(state_get "$repo" prior)
    deployedAt=$(state_get "$repo" deployedAt)
    cid=$(compose ps -q "$compose_svc" 2>/dev/null || true)
    if [[ -n "$cid" ]]; then
      health_status=$(docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{if .State.Running}}running{{else}}stopped{{end}}{{end}}' "$cid" 2>/dev/null || echo unknown)
    else
      health_status="not-running"
    fi
    printf '%s%s%s\n' "${C_CYAN}" "$svc_id" "${C_RESET}"
    printf '  current:    %s\n' "${cur:-<none>}"
    printf '  prior:      %s\n' "${prior:-<none>}"
    printf '  deployedAt: %s\n' "${deployedAt:-<none>}"
    printf '  container:  %s\n\n' "$health_status"
  done
}

cmd_logs() {
  if [[ ! -s "$LOG_FILE" ]]; then
    warn "Log is empty: $LOG_FILE"
    return 0
  fi
  tail -n 50 "$LOG_FILE"
}

# Show or set this box's component scope (FORGE_DEPLOY_SERVICES in .env).
# With no arg: prints current scope. With an arg: validates + writes it.
# This is the building block the first-run wizard uses; operators can also
# call it directly to declare "this box is UI-only" without hand-editing .env.
cmd_components() {
  local newval="${1:-}"
  if [[ ! -f "$ENV_FILE" ]]; then
    die "Env file not found: $ENV_FILE (run setup.sh first)"
  fi
  if [[ -z "$newval" ]]; then
    local cur
    cur=$(env_get FORGE_DEPLOY_SERVICES 2>/dev/null || true)
    if [[ -z "$cur" ]]; then
      printf 'FORGE_DEPLOY_SERVICES: %s(not set — defaults to all)%s\n' "${C_DIM}" "${C_RESET}"
    else
      printf 'FORGE_DEPLOY_SERVICES: %s\n' "$cur"
    fi
    printf 'This box deploys:      %s\n' "$(box_service_ids | tr '\n' ' ' | sed 's/ $//')"
    printf '\n%sValid components: %sall%s\n' "${C_DIM}" "$(all_service_ids | tr '\n' ' ')" "${C_RESET}"
    printf '%sSet with: forge-deploy --components "ui"%s\n' "${C_DIM}" "${C_RESET}"
    return 0
  fi
  if [[ ! -w "$ENV_FILE" ]]; then
    die "Env file not writable: $ENV_FILE"
  fi
  local norm token out=""
  norm=$(printf '%s' "$newval" | tr ',' ' ' | tr -s '[:space:]' ' ' | sed 's/^ //;s/ $//')
  for token in $norm; do
    if [[ "$token" == "all" ]]; then
      out=$(all_service_ids | tr '\n' ' ' | sed 's/ $//'); break
    elif all_service_ids | grep -qx "$token"; then
      out="${out}${token} "
    else
      die "Unknown component '$token' (valid: $(all_service_ids | tr '\n' ' ')all)"
    fi
  done
  out=$(printf '%s' "$out" | sed 's/ $//')
  [[ -n "$out" ]] || die "No valid components given"
  env_set FORGE_DEPLOY_SERVICES "$out"
  ok "Set FORGE_DEPLOY_SERVICES=$out"
  printf 'This box now deploys: %s\n' "$(box_service_ids | tr '\n' ' ' | sed 's/ $//')"
}

# ─────────────────────────────────────────────────────────────
# Component wizard (scope this box down — remove unwanted services)
# ─────────────────────────────────────────────────────────────

# Container runtime state for a name: running | exited | created | absent.
container_state() {
  local name="$1" st
  st=$(docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "")
  [[ -z "$st" ]] && { printf 'absent'; return; }
  printf '%s' "$st"
}

stack_field() {
  # stack_field <compose_name> <1..4>
  local name="$1" idx="$2" entry
  for entry in "${STACK_SERVICES[@]}"; do
    if [[ "${entry%%|*}" == "$name" ]]; then
      IFS='|' read -r _c _g _s _l <<<"$entry"
      case "$idx" in 1) printf '%s' "$_c";; 2) printf '%s' "$_g";; 3) printf '%s' "$_s";; 4) printf '%s' "$_l";; esac
      return 0
    fi
  done
  return 1
}

# Known depends_on edges in the stack. Used to drop edges that would point at a
# scoped-out service — compose rejects the whole project otherwise ("depends on
# undefined service ..."), which breaks EVERY compose command on the box.
service_deps() {
  case "$1" in
    forge-ui)     printf 'forge-api' ;;
    forge-api)    printf 'forge forge-storage' ;;
    forge-backup) printf 'forge forge-storage' ;;
    *)            printf '' ;;
  esac
}

# Regenerate the per-box scope from a space-separated list of compose service
# names to scope OUT. Idempotent — rewrites everything from the given list:
#   1. docker-compose.scope.yml  — profiles-out each service (bare `up` skips it)
#   2. FORGE_SCOPED_OUT in .env   — flat roster read by setup.sh / refresh.sh
#   3. FORGE_DEPLOY_SERVICES      — versioned ids (api/ui/test) NOT scoped out
#   4. COMPOSE_FILE               — append/strip the scope file so bare compose honors it
write_scope() {
  local scoped_out
  # `{ grep || true; }` so a no-match (empty $1, i.e. role=all) doesn't poison
  # the pipeline under `set -euo pipefail` — pipefail otherwise propagates
  # grep's exit-1, which silently aborts the wizard right after the
  # "Scoping components for 'all'" banner.
  scoped_out=$(printf '%s\n' $1 | { grep -v '^$' || true; } | sort -u | tr '\n' ' ' | sed 's/ *$//')

  if [[ -z "$scoped_out" ]]; then
    rm -f "$COMPOSE_SCOPE"
  else
    {
      printf '# Generated by `forge-deploy --wizard` — DO NOT edit by hand.\n'
      printf '# Per-box component scope: these services are profiled out so a bare\n'
      printf '# `docker compose up` (and --remove-orphans) will not start them here.\n'
      printf '# Re-run the wizard to change; delete this file to clear all scoping.\n'
      printf 'services:\n'
      local s
      for s in $scoped_out; do
        printf '  %s:\n    profiles: ["scoped-out"]\n' "$s"
      done
      # depends_on hygiene: a KEPT service whose depends_on points at a
      # scoped-out service makes the whole project invalid. Reset that edge.
      # (e.g. UI box: forge-ui kept, forge-api scoped -> drop forge-ui's edge.)
      local dependent deps d need
      for dependent in forge-ui forge-api forge-backup; do
        printf '%s\n' $scoped_out | grep -qx "$dependent" && continue
        deps=$(service_deps "$dependent"); need=0
        for d in $deps; do printf '%s\n' $scoped_out | grep -qx "$d" && need=1; done
        (( need )) && printf '  %s:\n    depends_on: !reset null\n' "$dependent"
      done
    } > "$COMPOSE_SCOPE"
  fi

  env_set FORGE_SCOPED_OUT "$scoped_out"

  local keep="" entry cname sid
  for entry in "${STACK_SERVICES[@]}"; do
    IFS='|' read -r cname _grp sid _label <<<"$entry"
    [[ "$sid" == "-" ]] && continue
    printf '%s\n' $scoped_out | grep -qx "$cname" && continue
    keep+="$sid "
  done
  env_set FORGE_DEPLOY_SERVICES "$(printf '%s' "$keep" | sed 's/ *$//')"

  local cf
  cf=$(env_get COMPOSE_FILE 2>/dev/null || true)
  if [[ -n "$cf" ]]; then
    if [[ -n "$scoped_out" && ":$cf:" != *":docker-compose.scope.yml:"* ]]; then
      env_set COMPOSE_FILE "${cf}:docker-compose.scope.yml"
    elif [[ -z "$scoped_out" ]]; then
      cf=$(printf '%s' "$cf" | sed 's/:docker-compose\.scope\.yml//g; s/docker-compose\.scope\.yml://g; s/^docker-compose\.scope\.yml$//')
      env_set COMPOSE_FILE "$cf"
    fi
  fi
}

cmd_wizard() {
  [[ -f "$ENV_FILE" ]] || die "Env file not found: $ENV_FILE (run setup.sh first)"
  [[ -w "$ENV_FILE" ]] || die "Env file not writable: $ENV_FILE (sudo chown -R \$(id -un):\$(id -gn) $REPO_ROOT)"
  require_cmd docker

  printf '\n%s== forge-deploy component wizard ==%s\n' "${C_BOLD}${C_CYAN}" "${C_RESET}"
  printf 'Select which installed components to REMOVE from THIS box. Removing a\n'
  printf 'component stops + deletes its container and prevents auto-recreate\n'
  printf '(no images are pulled, nothing is started).\n'
  printf '%sNote: data volumes are NOT deleted — removing a container keeps its data.%s\n' "${C_DIM}" "${C_RESET}"

  local entry cname grp label st present=() idx_map=()
  for entry in "${STACK_SERVICES[@]}"; do
    IFS='|' read -r cname grp _sid label <<<"$entry"
    st=$(container_state "$cname")
    [[ "$st" == "absent" ]] && continue
    present+=("$cname")
  done
  if (( ${#present[@]} == 0 )); then
    warn "No forge containers detected on this box — nothing to remove."
    return 0
  fi

  printf '\nDetected components:\n'
  local i=1
  for cname in "${present[@]}"; do
    st=$(container_state "$cname")
    grp=$(stack_field "$cname" 2); label=$(stack_field "$cname" 4)
    printf '  %s[%d]%s %-14s %s%-9s%s %s%s%s\n' \
      "${C_BOLD}" "$i" "${C_RESET}" "$cname" "${C_DIM}" "($st)" "${C_RESET}" \
      "$([[ "$grp" == backend ]] && printf '%s' "$C_YELLOW")" "$label" "$C_RESET"
    idx_map+=("$cname")
    i=$((i+1))
  done
  printf '%s(backend tier shown in amber — keep these on an API box)%s\n' "${C_DIM}" "${C_RESET}"

  printf '\nEnter numbers to REMOVE (space/comma separated), or q to cancel: '
  local input; read -r input
  [[ -z "$input" || "$input" == "q" || "$input" == "Q" ]] && { warn "Cancelled — no changes made."; return 0; }

  local remove=() n
  for n in $(printf '%s' "$input" | tr ',' ' '); do
    { [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#idx_map[@]} )); } || die "Invalid selection: $n"
    remove+=("${idx_map[$((n-1))]}")
  done

  # Sanity: removing the DB while keeping the API will break the API.
  local has_db=0 keeps_api=0 r
  for r in "${remove[@]}"; do [[ "$r" == "forge" ]] && has_db=1; done
  container_state forge-api | grep -qv absent && keeps_api=1
  for r in "${remove[@]}"; do [[ "$r" == "forge-api" ]] && keeps_api=0; done
  if (( has_db == 1 && keeps_api == 1 )); then
    warn "You're removing the database (forge) but keeping forge-api — the API needs it."
  fi

  printf '\n%sWill remove:%s %s\n' "${C_YELLOW}${C_BOLD}" "${C_RESET}" "${remove[*]}"
  printf 'Proceed? Stops + deletes those containers (volumes untouched). [y/N]: '
  local confirm; read -r confirm
  [[ "$confirm" == "y" || "$confirm" == "Y" ]] || { warn "Cancelled — no changes made."; return 0; }

  # Remove containers BEFORE writing the scope file (once profiled-out, compose
  # may no longer target them).
  local svc
  for svc in "${remove[@]}"; do
    step "Removing $svc"
    compose stop "$svc" >/dev/null 2>&1 || docker stop "$svc" >/dev/null 2>&1 || true
    compose rm -sf "$svc" >/dev/null 2>&1 || docker rm -f "$svc" >/dev/null 2>&1 || true
    ok "$svc stopped + removed"
  done

  # Merge with anything already scoped out, then persist.
  local existing; existing=$(env_get FORGE_SCOPED_OUT 2>/dev/null || true)
  write_scope "$existing ${remove[*]}"

  ok "FORGE_SCOPED_OUT = $(env_get FORGE_SCOPED_OUT)"
  ok "FORGE_DEPLOY_SERVICES = $(env_get FORGE_DEPLOY_SERVICES) (this box deploys: $(box_scope_label))"
  [[ -f "$COMPOSE_SCOPE" ]] && ok "Wrote docker-compose.scope.yml (profiles-out removed services)"

  printf '\n%sDone.%s No services were started. Bring up the remaining stack when ready:\n' "${C_GREEN}${C_BOLD}" "${C_RESET}"
  printf '  %sforge-deploy --status%s         # what is/should be running here\n' "${C_DIM}" "${C_RESET}"
  printf '  %sforge-deploy --service api%s    # deploy/refresh the backend to a pinned tag\n' "${C_DIM}" "${C_RESET}"
}

# ─────────────────────────────────────────────────────────────
# Wrapped bring-up + compose passthrough (never run bare docker compose)
# ─────────────────────────────────────────────────────────────

# Bring up ONLY this box's components — never recreate scoped-out services.
# This is the blessed alternative to a bare `docker compose up -d`, which would
# start every service in the file set and resurrect the components you removed.
cmd_up() {
  preflight

  # Core (always-on) services in dependency order: data tier, then api, then ui.
  # Optional/profile services (ai/tts/logs/signing/test) are opt-in and brought
  # up separately with their profiles — never by this command.
  local up_order=(forge forge-storage forge-backup forge-api forge-ui)
  local services=() s
  for s in "${up_order[@]}"; do
    is_scoped_out "$s" || services+=("$s")
  done
  (( ${#services[@]} )) || die "Nothing to bring up — every core service is scoped out on this box."

  # Refuse to start on a floating 'latest' tag (the crash-loop foot-gun).
  local v
  for s in "${services[@]}"; do
    case "$s" in
      forge-api) v=SERVER_IMAGE_TAG ;;
      forge-ui)  v=UI_IMAGE_TAG ;;
      *)         v="" ;;
    esac
    [[ -n "$v" && "$(env_get "$v")" == "latest" ]] && \
      die "$v=latest — pin an immutable tag first (forge-deploy <X.Y.Z|main-sha>), then retry"
  done

  # Broken frontier: a kept service depends on a scoped-out one (forge-ui→forge-api
  # on a UI box). --no-deps stops compose from trying to pull the removed
  # dependency back in (the only cross-scope edge in the stack).
  local nodeps=""
  if printf '%s\n' "${services[@]}" | grep -qx forge-ui && is_scoped_out forge-api; then
    nodeps="--no-deps"
  fi

  step "Bringing up this box: ${services[*]}${nodeps:+  ($nodeps)}"
  # shellcheck disable=SC2086  # $nodeps is intentionally word-split (empty or --no-deps)
  compose up -d $nodeps "${services[@]}"
  ok "Up. Scoped-out services were NOT started (forge-deploy --wizard removes them for good)."
  cmd_status
}

# Scope-aware `docker compose` passthrough. Always injects the correct -f set
# (base + cohost + scope overlay) and --env-file, so operators never hand-build
# a bare `docker compose` invocation that ignores the per-box scope.
#   forge-deploy compose ps
#   forge-deploy compose logs -f forge-api
#   forge-deploy compose stop
cmd_compose() {
  preflight
  [[ $# -gt 0 ]] || die "forge-deploy compose <args> — e.g. 'compose ps', 'compose logs -f forge-api'"
  compose "$@"
}

# Point forge-api at a remote Postgres + MinIO (api/ui+api box, separate db box).
# Writes DB_HOST/DB_PORT/MINIO_ENDPOINT to .env (compose interpolates them into
# forge-api's ConnectionStrings + Minio__Endpoint, which default to the local
# forge/forge-storage services). POSTGRES_*/MINIO_* creds must match the db box.
#   forge-deploy --remote-db 192.168.1.50            (Postgres host, default :5432)
#   forge-deploy --remote-db 192.168.1.50:5432 --minio 192.168.1.50:9000
#   forge-deploy --remote-db                          (show current)
#   forge-deploy --remote-db off                      (revert to local forge/forge-storage)
cmd_remote_db() {
  local pg="$1" minio="$2"
  [[ -f "$ENV_FILE" ]] || die "Env file not found: $ENV_FILE (run setup.sh first)"

  if [[ -z "$pg" || "$pg" == "show" ]]; then
    printf 'DB_HOST:        %s\n' "$(env_get DB_HOST 2>/dev/null || echo '(unset -> forge, local)')"
    printf 'DB_PORT:        %s\n' "$(env_get DB_PORT 2>/dev/null || echo '(unset -> 5432)')"
    printf 'MINIO_ENDPOINT: %s\n' "$(env_get MINIO_ENDPOINT 2>/dev/null || echo '(unset -> forge-storage:9000, local)')"
    return 0
  fi
  [[ -w "$ENV_FILE" ]] || die "Env file not writable: $ENV_FILE"

  if [[ "$pg" == "off" || "$pg" == "clear" ]]; then
    local tmp; tmp=$(mktemp)
    grep -vE '^(DB_HOST|DB_PORT|MINIO_ENDPOINT|MINIO_HOST|MINIO_PORT)=' "$ENV_FILE" > "$tmp" && mv "$tmp" "$ENV_FILE"
    ok "Reverted to local DB/MinIO (forge / forge-storage)"
    return 0
  fi

  local host port
  host="${pg%%:*}"; port="${pg##*:}"; [[ "$port" == "$host" ]] && port="5432"
  env_set DB_HOST "$host"
  env_set DB_PORT "$port"
  ok "forge-api -> Postgres ${host}:${port}"
  # Fail fast BEFORE any redeploy if the remote DB (and MinIO, if given) is
  # unreachable — non-destructive: nothing has been recreated yet. During
  # --setup (SETUP_QUIET=1) the db box may legitimately not be up yet, so we
  # only warn there; the real gate is the pre-deploy check in deploy_service.
  if ! check_remote_reachable "$host" "$port" "$minio"; then
    if [[ -n "${SETUP_QUIET:-}" ]]; then
      warn "Remote DB/MinIO not reachable yet — wiring config anyway; the deploy will re-check"
    else
      die "Remote DB/MinIO not reachable — fix connectivity (or the db box) and retry"
    fi
  fi
  if [[ -n "$minio" ]]; then
    [[ "$minio" == *:* ]] || minio="${minio}:9000"
    env_set MINIO_ENDPOINT "$minio"
    # The backup sidecar reads MINIO_HOST/MINIO_PORT (not MINIO_ENDPOINT), and
    # compose interpolation can't split host:port — so mirror the endpoint into
    # the split vars the sidecar consumes.
    env_set MINIO_HOST "${minio%%:*}"
    env_set MINIO_PORT "${minio##*:}"
    ok "forge-api -> MinIO ${minio}"
  fi
  printf '\n%sNote:%s POSTGRES_USER/PASSWORD/DB and MINIO_ROOT_USER/PASSWORD in this .env\n' "${C_YELLOW}" "${C_RESET}"
  printf '      must match the db box. Redeploy to apply: forge-deploy --service api <tag> (or --up).\n'
}

# ── Edge (host reverse-proxy vhost) ──────────────────────────────────────────
readonly EDGE_TAG="forge-deploy"

# Render a topology-correct nginx vhost to stdout.
# Args: host ui_target api_target cert key
render_edge_vhost() {
  local host="$1" ui="$2" api="$3" cert="$4" key="$5"
  cat <<EOF
# Generated by \`forge-deploy --edge\` — DO NOT edit by hand (it will be overwritten).
# Topology: SPA -> ${ui} ; /api,/hubs,OIDC -> ${api}
map \$http_upgrade \$forge_conn_upgrade { default upgrade; '' close; }

server {
    listen 80;
    listen [::]:80;
    server_name ${host};
    return 301 https://\$host\$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name ${host};

    ssl_certificate     ${cert};
    ssl_certificate_key ${key};
    ssl_protocols       TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;

    proxy_buffer_size       16k;
    proxy_buffers         8 16k;
    proxy_busy_buffers_size 32k;
    client_max_body_size  100m;

    # ---- API + SignalR + OIDC -> API target ----
    location /api/                  { proxy_pass http://${api}; $(edge_proxy_headers) }
    location /hubs/                 { proxy_pass http://${api}; $(edge_proxy_headers) proxy_read_timeout 86400s; proxy_send_timeout 86400s; }
    location = /signin-oidc         { proxy_buffering off; proxy_pass http://${api}; $(edge_proxy_headers) }
    location = /signout-callback-oidc { proxy_buffering off; proxy_pass http://${api}; $(edge_proxy_headers) }
    location /connect/              { proxy_pass http://${api}; $(edge_proxy_headers) }
    location /.well-known/          { proxy_pass http://${api}; $(edge_proxy_headers) }

    # ---- SPA -> UI target ----
    location / { proxy_pass http://${ui}; $(edge_proxy_headers) }
}
EOF
}

# Standard proxy headers (incl. WebSocket upgrade) emitted inline.
edge_proxy_headers() {
  printf 'proxy_http_version 1.1; proxy_set_header Upgrade $http_upgrade; proxy_set_header Connection $forge_conn_upgrade; proxy_set_header Host $host; proxy_set_header X-Real-IP $remote_addr; proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for; proxy_set_header X-Forwarded-Proto $scheme; proxy_set_header X-Forwarded-Host $host;'
}

# Auto-detect a Let's Encrypt cert covering the host (or its parent domain).
edge_detect_cert() {
  local host="$1" d
  for d in /etc/letsencrypt/live/*/; do
    [[ -f "${d}fullchain.pem" ]] || continue
    # match exact host dir, or a parent-domain wildcard dir (e.g. armoryworks.com*)
    local name; name=$(basename "$d")
    if [[ "$host" == "$name" || "$host" == *".${name%%.cloudflare}" || "$name" == "${host#*.}"* ]]; then
      printf '%s' "${d}fullchain.pem"; return 0
    fi
  done
  return 1
}

# Generate + install + reload the host nginx vhost for the public hostname.
#   forge-deploy --edge --host forge.x.com --ui 127.0.0.1:4200 --api 192.168.1.198:5000 [--cert .. --key ..]
cmd_edge() {
  command -v nginx >/dev/null 2>&1 || sudo test -x /usr/sbin/nginx || die "host nginx not found (the edge generator targets host nginx)"
  local host="$EDGE_HOST" ui="${EDGE_UI:-127.0.0.1:4200}" api="$EDGE_API" cert="$EDGE_CERT" key="$EDGE_KEY"

  [[ -n "$host" ]] || { printf 'Public hostname (e.g. forge.example.com): '; read -r host; }
  [[ -n "$host" ]] || die "--edge requires --host"
  [[ -n "$api" ]] || api="127.0.0.1:5000"
  api="${api#http://}"; api="${api#https://}"; api="${api%/}"
  ui="${ui#http://}";   ui="${ui%/}"

  if [[ -z "$cert" ]]; then
    cert=$(edge_detect_cert "$host" || true)
    [[ -n "$cert" ]] && ok "Detected cert: $cert" || { printf 'TLS fullchain.pem path: '; read -r cert; }
  fi
  [[ -n "$key" ]] || key="${cert%fullchain.pem}privkey.pem"
  [[ -f "$cert" ]] || warn "cert not found: $cert (nginx -t will fail until it exists)"

  # Pick the include dir nginx actually loads from.
  local dir="/etc/nginx/conf.d" target
  [[ -d /etc/nginx/conf.d ]] || dir="/etc/nginx/sites-enabled"
  target="${dir}/${EDGE_TAG}-${host}.conf"

  step "Rendering edge vhost for ${host}  (SPA->${ui}, API->${api})"
  local rendered; rendered=$(mktemp)
  render_edge_vhost "$host" "$ui" "$api" "$cert" "$key" > "$rendered"

  # Neutralize conflicting server blocks for this host in OTHER active confs.
  local f bak conflicts
  conflicts=$(sudo grep -rlE "server_name[^;]*[[:space:]]${host}[;[:space:]]|server_name[[:space:]]+${host}[;[:space:]]" "$dir" /etc/nginx/sites-enabled 2>/dev/null | grep -vF "$target" | sort -u || true)
  for f in $conflicts; do
    bak="${f}.forge-bak.$(date -u +%Y%m%d-%H%M%S)"
    step "Disabling existing '${host}' vhost in $f (backup: $bak)"
    sudo cp "$f" "$bak"
    sudo awk -v host="$host" -v tag="$EDGE_TAG" '
      function emit(){ if(matched){ n=split(buf,L,"\n"); for(i=1;i<=n;i++){ if(i==n && L[i]=="") break; print "# [" tag " disabled] " L[i] } } else printf "%s", buf; buf=""; depth=0; inblk=0; matched=0 }
      { if(!inblk && $0 ~ /^[[:space:]]*server[[:space:]]*\{/){ inblk=1; depth=0 }
        if(inblk){ buf=buf $0 "\n"; o=gsub(/\{/,"{"); c=gsub(/\}/,"}"); depth+=o-c;
          if($0 ~ ("server_name[^;]*[[:space:]]" host "[;[:space:]]") || $0 ~ ("server_name[[:space:]]+" host "[;[:space:]]")) matched=1;
          if(depth<=0) emit(); next } print }
    ' "$bak" | sudo tee "$f" >/dev/null
  done

  # Install our conf, validate, reload — restore everything on failure.
  local prev_bak=""
  if sudo test -f "$target"; then prev_bak="${target}.forge-bak.$(date -u +%Y%m%d-%H%M%S)"; sudo cp "$target" "$prev_bak"; fi
  sudo tee "$target" < "$rendered" >/dev/null
  rm -f "$rendered"
  ok "Wrote $target"

  if sudo nginx -t 2>/dev/null; then
    if [[ -z "${EDGE_NO_RELOAD:-}" ]]; then
      sudo systemctl reload nginx 2>/dev/null || sudo nginx -s reload
      ok "nginx reloaded — ${host} now serves SPA from ${ui}, API from ${api}"
    else
      ok "nginx config valid (skipped reload: --no-reload)"
    fi
  else
    err "nginx -t failed — rolling back all edge changes"
    [[ -n "$prev_bak" ]] && sudo cp "$prev_bak" "$target" || sudo rm -f "$target"
    for f in $conflicts; do
      bak=$(sudo ls -1t "${f}.forge-bak."* 2>/dev/null | head -1); [[ -n "$bak" ]] && sudo cp "$bak" "$f"
    done
    sudo nginx -t 2>&1 | tail -3
    die "Edge vhost rejected by nginx -t — restored previous config. Fix cert/host and retry."
  fi
}

# Wire forge-ui's /api + /hubs to a remote API server (UI-only box). Stands up
# a tiny nginx forwarder on the `forge-api` network alias, so forge-ui's baked
# `http://forge-api:8080` target resolves to the forwarder, which relays to the
# real API on another box. No forge-ui image rebuild needed.
#   forge-deploy --remote-api http://10.0.0.12:5000
#   forge-deploy --remote-api https://api.example.com
#   forge-deploy --remote-api            (show current)
#   forge-deploy --remote-api off        (tear down the wiring)
cmd_remote_api() {
  local target="$1"
  [[ -f "$ENV_FILE" ]] || die "Env file not found: $ENV_FILE (run setup.sh first)"
  require_cmd docker

  if [[ -z "$target" || "$target" == "show" ]]; then
    if [[ -f "$REMOTE_API_CONF" ]]; then
      ok "Remote-API wiring ACTIVE"
      grep -m1 'set \$upstream' "$REMOTE_API_CONF" 2>/dev/null | sed -E 's/.*"(.*)".*/  target: \1/'
    else
      printf 'No remote-API wiring. Set with: %sforge-deploy --remote-api http://<api-box-ip>:<port>%s\n' "${C_BOLD}" "${C_RESET}"
    fi
    return 0
  fi

  [[ -w "$ENV_FILE" ]] || die "Env file not writable: $ENV_FILE (sudo chown -R \$(id -un):\$(id -gn) $REPO_ROOT)"

  if [[ "$target" == "off" || "$target" == "clear" ]]; then
    step "Removing remote-API wiring"
    compose stop forge-api-proxy >/dev/null 2>&1 || docker stop forge-api-proxy >/dev/null 2>&1 || true
    compose rm -sf forge-api-proxy >/dev/null 2>&1 || docker rm -f forge-api-proxy >/dev/null 2>&1 || true
    rm -f "$COMPOSE_REMOTE_API" "$REMOTE_API_CONF"
    local cf; cf=$(env_get COMPOSE_FILE 2>/dev/null || true)
    [[ -n "$cf" ]] && env_set COMPOSE_FILE "$(printf '%s' "$cf" | sed 's/:docker-compose\.remote-api\.yml//g; s/docker-compose\.remote-api\.yml://g; s/^docker-compose\.remote-api\.yml$//')"
    ok "Removed. (forge-api alias no longer forwards — re-add a local API or another --remote-api)"
    return 0
  fi

  # Normalize scheme + parse host[:port].
  [[ "$target" =~ ^https?:// ]] || target="http://$target"
  local scheme host
  scheme="${target%%://*}"
  host="${target#*://}"; host="${host%%/*}"
  [[ -n "$host" ]] || die "Invalid target: '$target' (expected scheme://host:port)"

  step "Wiring forge-ui /api + /hubs -> $target"

  # HTTPS upstreams need SNI + a real Host header for vhost routing.
  local ssl_lines=""
  if [[ "$scheme" == "https" ]]; then
    ssl_lines=$'        proxy_ssl_server_name on;\n        proxy_set_header Host '"${host%%:*}"';'
  fi

  cat > "$REMOTE_API_CONF" <<EOF
# Generated by \`forge-deploy --remote-api\` — DO NOT edit by hand.
# UI-only box stand-in for forge-api: forge-ui's image proxies to
# http://forge-api:8080 (baked); this answers on the \`forge-api\` network alias
# and forwards to the real API on another server. Remove: forge-deploy --remote-api off
map \$http_upgrade \$connection_upgrade { default upgrade; '' close; }
server {
    listen 8080;
    resolver 127.0.0.11 valid=30s ipv6=off;
    client_max_body_size 100m;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    location / {
        set \$upstream "$target";
        proxy_pass \$upstream;
        proxy_http_version 1.1;
        proxy_set_header X-Real-IP         \$remote_addr;
        proxy_set_header X-Forwarded-For   \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_set_header Upgrade           \$http_upgrade;
        proxy_set_header Connection        \$connection_upgrade;
$ssl_lines
    }
}
EOF

  cat > "$COMPOSE_REMOTE_API" <<'EOF'
# Generated by `forge-deploy --remote-api` — DO NOT edit by hand.
# Stand-in for forge-api on a UI-only box: serves the `forge-api` network alias
# and forwards /api + /hubs to the real API server (see forge-api-proxy.conf).
# Remove with: forge-deploy --remote-api off
services:
  forge-api-proxy:
    image: nginx:alpine
    container_name: forge-api-proxy
    restart: unless-stopped
    volumes:
      - ./forge-api-proxy.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      default:
        aliases:
          - forge-api
EOF
  ok "Wrote forge-api-proxy.conf + docker-compose.remote-api.yml"

  # Scope out the real forge-api so it can't crash-loop or fight for the alias.
  local existing; existing=$(env_get FORGE_SCOPED_OUT 2>/dev/null || true)
  write_scope "$existing forge-api"
  ok "Scoped out local forge-api (FORGE_DEPLOY_SERVICES = $(box_scope_label))"

  # Add the override to COMPOSE_FILE so bare/scoped compose sees the forwarder.
  local cf; cf=$(env_get COMPOSE_FILE 2>/dev/null || true)
  if [[ -n "$cf" && ":$cf:" != *":docker-compose.remote-api.yml:"* ]]; then
    env_set COMPOSE_FILE "${cf}:docker-compose.remote-api.yml"
  fi

  step "Starting forge-api-proxy + forge-ui"
  compose up -d --no-deps forge-api-proxy
  compose up -d --no-deps forge-ui
  ok "Wired. forge-ui /api + /hubs now forward to $target."

  printf '\n%sPrerequisite — the API box must be reachable at %s from THIS box:%s\n' "${C_YELLOW}${C_BOLD}" "$target" "${C_RESET}"
  printf '  • On the API box, publish the API on a reachable interface — set %sAPI_BIND=0.0.0.0%s\n' "${C_BOLD}" "${C_RESET}"
  printf '    (or its LAN IP) in .env and redeploy; by default it binds 127.0.0.1 (local-only).\n'
  printf '  • Verify from here: %scurl -sS %s/api/v1/health%s\n' "${C_DIM}" "$target" "${C_RESET}"
}

# ── Topology setup wizard ────────────────────────────────────────────────────
# Roles and the compose services each one scopes OUT (everything else runs local).
role_scoped_out() {
  case "$1" in
    all)     printf '' ;;
    ui+api)  printf 'forge forge-storage forge-backup' ;;   # no db -> remote
    api+db)  printf 'forge-ui' ;;                            # no ui  (ui is remote)
    ui)      printf 'forge-api forge forge-storage forge-backup' ;;
    api)     printf 'forge-ui forge forge-storage forge-backup' ;;  # no ui, no db
    db)      printf 'forge-ui forge-api' ;;                  # db + storage + backup
    *)       return 1 ;;
  esac
}
role_valid() { role_scoped_out "$1" >/dev/null 2>&1; }
# Does the role run a local forge-<svc>?
role_runs() { ! printf '%s\n' $(role_scoped_out "$1") | grep -qx "$2"; }

cmd_setup() {
  if [[ ! -f "$ENV_FILE" ]]; then
    step "No configuration found — running first-time bootstrap"
    run_bootstrap || die "Bootstrap failed — run 'forge-deploy --recover' to diagnose and resume."
  fi
  [[ -w "$ENV_FILE" ]] || die "Env file not writable: $ENV_FILE (sudo chown -R \$(id -un):\$(id -gn) $REPO_ROOT)"

  local role="$SETUP_ROLE"
  if [[ -z "$role" ]]; then
    printf '\n%s== forge-deploy topology setup ==%s\n' "${C_BOLD}${C_CYAN}" "${C_RESET}"
    printf 'What does THIS box run?\n'
    printf '  %s1%s) all       — ui + api + db (single box)\n' "${C_BOLD}" "${C_RESET}"
    printf '  %s2%s) ui+api    — ui + api here, db on another box\n' "${C_BOLD}" "${C_RESET}"
    printf '  %s3%s) api+db    — api + db here, ui on another box\n' "${C_BOLD}" "${C_RESET}"
    printf '  %s4%s) ui        — ui only (api + db remote)\n' "${C_BOLD}" "${C_RESET}"
    printf '  %s5%s) api       — api only (db remote, ui remote)\n' "${C_BOLD}" "${C_RESET}"
    printf '  %s6%s) db        — database + storage only\n' "${C_BOLD}" "${C_RESET}"
    printf 'Choose [1-6]: '
    local c; read -r c
    case "$c" in 1) role=all;; 2) role=ui+api;; 3) role=api+db;; 4) role=ui;; 5) role=api;; 6) role=db;; *) die "Invalid choice";; esac
  fi
  role_valid "$role" || die "Unknown role '$role' (all|ui+api|api+db|ui|api|db)"
  step "Role: $role"

  require_cmd docker; require_cmd jq

  local api_url="$SETUP_API_URL" db_host="$SETUP_DB_HOST" minio="$SETUP_MINIO" pub_host="$EDGE_HOST"
  local has_nginx=0; { command -v nginx >/dev/null 2>&1 || sudo test -x /usr/sbin/nginx 2>/dev/null; } && has_nginx=1

  # Gather what this role needs (prompt only if not supplied as a flag).
  if role_runs "$role" forge-ui && ! role_runs "$role" forge-api; then   # ui without local api
    [[ -n "$api_url" ]] || { printf 'API box URL (e.g. http://192.168.1.198:5000): '; read -r api_url; }
    [[ -n "$api_url" ]] || die "role '$role' needs --api-url"
  fi
  if role_runs "$role" forge-api && ! role_runs "$role" forge; then       # api without local db
    [[ -n "$db_host" ]] || { printf 'DB box host[:port] (e.g. 192.168.1.50): '; read -r db_host; }
    [[ -n "$db_host" ]] || die "role '$role' needs --db-host"
    [[ -n "$minio" ]] || { printf 'MinIO host[:port] (Enter = same as DB host:9000): '; read -r minio; [[ -z "$minio" ]] && minio="${db_host%%:*}:9000"; }
  fi
  if role_runs "$role" forge-ui && [[ "$has_nginx" == 1 ]]; then          # serves the public site via host nginx
    [[ -n "$pub_host" ]] || { printf 'Public hostname for the edge (e.g. forge.example.com): '; read -r pub_host; }
  fi

  # 1. Scope the containers for this role.
  step "Scoping components for '$role'"
  write_scope "$(role_scoped_out "$role")"
  ok "FORGE_SCOPED_OUT = $(env_get FORGE_SCOPED_OUT | sed 's/^$/(none)/')"

  # 2. Remote DB/MinIO (api without local db).
  if role_runs "$role" forge-api && ! role_runs "$role" forge; then
    SETUP_QUIET=1 cmd_remote_db "$db_host" "$minio"
  fi
  # 3. DB box: expose Postgres + MinIO on the LAN.
  if [[ "$role" == "db" ]]; then
    env_set POSTGRES_BIND 0.0.0.0; env_set MINIO_BIND 0.0.0.0
    ok "Exposed Postgres + MinIO on 0.0.0.0 (LAN-reachable for the api box)"
  fi
  # 4. UI without local api: edge split (host nginx) or in-container forwarder (standalone).
  local api_target="127.0.0.1:5000"
  if role_runs "$role" forge-ui && ! role_runs "$role" forge-api; then
    if [[ "$has_nginx" == 1 ]]; then
      api_target="${api_url#http://}"; api_target="${api_target#https://}"; api_target="${api_target%/}"
    else
      cmd_remote_api "$api_url"   # forge-ui is the public edge -> forwarder
    fi
  fi
  # 5. Edge vhost (only when this box fronts the public site via host nginx).
  if role_runs "$role" forge-ui && [[ "$has_nginx" == 1 && -n "$pub_host" ]]; then
    EDGE_HOST="$pub_host" EDGE_UI="127.0.0.1:4200" EDGE_API="$api_target" cmd_edge
  fi
  # 5b. Pick a version for each versioned component (default = newest on first run).
  local vsvc vrc vchosen
  for vsvc in $(box_service_ids); do
    vrc=0; vchosen=$(pick_component_version "$vsvc") || vrc=$?
    (( vrc == 20 )) && { warn "Setup cancelled before bring-up (run forge-deploy again to resume)."; return 0; }
    [[ -n "$vchosen" ]] && { validate_tag "$vchosen"; env_set "$(service_envvar "$vsvc")" "$vchosen"; ok "$vsvc pinned to $vchosen"; }
  done

  # 6. Bring up this box's containers.
  cmd_up

  # 7. Record the role.
  local tmp; tmp=$(mktemp)
  jq --arg r "$role" '.box = {role: $r, configuredAt: (now | todate)}' "$STATE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$STATE_FILE" || rm -f "$tmp"
  printf '\n%s✓ Setup complete — this box is role "%s".%s\n' "${C_GREEN}${C_BOLD}" "$role" "${C_RESET}"
}

# ─────────────────────────────────────────────────────────────
# Bootstrap doctor — detect common failure modes / incomplete
# setups, then heal-and-resume in place or restart from scratch.
#
# Design: state is inferred declaratively from artifacts (what
# setup.sh/deploys leave behind), never from a checkpoint file,
# so recovery works no matter HOW the box got into its state.
# ─────────────────────────────────────────────────────────────

readonly ISSUES_URL="https://github.com/armoryworks/forge-deploy/issues/new"
readonly CORE_CONTAINERS=(forge forge-storage forge-backup forge-api forge-ui)

# Findings from the last bootstrap_scan:
#   SCAN_HEAL  — tokens for problems we can fix automatically
#   SCAN_FATAL — plain-language actions only the user can take
SCAN_HEAL=()
SCAN_FATAL=()

scan_heal()  { SCAN_HEAL+=("$1"); warn "$2"; }
scan_fatal() { SCAN_FATAL+=("$1"); err "$1"; }

# What this recovery session did, for the issue's repro section. Appended by
# cmd_recover / cmd_fresh_start as they go: scan findings, heals, outcomes.
RECOVERY_TRACE=()
RECOVERY_ENTRY="forge-deploy"
trace() { RECOVERY_TRACE+=("$1"); }

# Redact credential-shaped values from a log stream.
sanitize() { sed -E 's/((password|passwd|pwd|secret|token|key|credential)[[:alnum:]_]*[=: ]+)[^;," ]*/\1***/Ig'; }

# Technical diagnostics for a bug report — rich enough to act on from the
# issue alone, but never secret-bearing: .env values are key-listed with
# credential-shaped values redacted; log tails pass through sanitize().
collect_diagnostics() {
  {
    printf '### Host\n```\n'
    uname -a 2>/dev/null || true
    grep -m1 PRETTY_NAME /etc/os-release 2>/dev/null || true
    printf 'RAM:  '; free -h 2>/dev/null | awk '/^Mem:/{print $2" total, "$7" available"}' || true
    printf 'Disk: '; df -h / 2>/dev/null | awk 'NR==2{print $2" total, "$4" free on /"}' || true
    printf '```\n\n### Docker\n```\n'
    docker --version 2>/dev/null || echo "docker: not found"
    docker compose version 2>/dev/null || echo "compose: not found"
    docker info --format 'root={{.DockerRootDir}}  cgroup={{.CgroupVersion}}/{{.CgroupDriver}}  storage={{.Driver}}  arch={{.Architecture}}' 2>/dev/null || echo "daemon: not reachable"
    printf 'forge-deploy %s  repo=%s\n' "$FORGE_DEPLOY_VERSION" "$REPO_ROOT"
    printf '```\n\n### Config (values redacted where credential-shaped)\n```\n'
    if [[ -f "$ENV_FILE" ]]; then
      awk -F= '/^[A-Za-z_][A-Za-z0-9_]*=/ {
        if ($1 ~ /(PASSWORD|PASSWD|PWD|SECRET|KEY|TOKEN|CREDENTIAL)/) print $1"=<redacted>";
        else { v=$0; sub(/^[^=]*=/,"",v); print $1"="v }
      }' "$ENV_FILE" 2>/dev/null
    else
      echo ".env: absent"
    fi
    printf '```\n\n### Deploy state\n```\n'
    cat "$STATE_FILE" 2>/dev/null || echo "state file absent"
    printf '\n```\n\n### Containers\n```\n'
    docker ps -a --filter "name=forge" --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}' 2>/dev/null || true
    printf '```\n\n### API health probe\n```\n'
    curl -fsS --max-time 3 "http://127.0.0.1:$(env_get API_PORT 2>/dev/null || echo 5000)/api/v1/health" 2>&1 | head -c 800 || echo "(no response)"
    printf '\n```\n\n### forge-api log tail (sanitized)\n```\n'
    docker logs forge-api --tail 60 2>&1 | sanitize || true
    printf '```\n\n### forge (db) log tail (sanitized)\n```\n'
    docker logs forge --tail 20 2>&1 | sanitize || true
    printf '```\n'
  } 2>/dev/null
}

# Frontloaded repro section: how the box got here this session.
collect_repro() {
  printf '## Steps to reproduce\n\n'
  printf '1. Ran `%s` on this box.\n' "$RECOVERY_ENTRY"
  local i=2 line
  for line in "${RECOVERY_TRACE[@]}"; do
    printf '%d. %s\n' "$i" "$line"
    (( i++ ))
  done
  printf '%d. Ended in the unrecoverable state described below.\n' "$i"
}

# Dead end we can't fix or identify: explain in plain language, hand the
# user the issue URL, and offer to auto-file when a gh login is present.
report_unrecoverable() {
  local title="$1" summary="$2"
  printf '\n%sThis needs a human — it could not be fixed automatically.%s\n' "${C_BOLD}${C_RED}" "${C_RESET}"
  printf '  %s\n\n' "$summary"
  printf '  Please open an issue (takes a minute, and we watch these):\n'
  printf '  %s%s?title=%s%s\n\n' "${C_CYAN}" "$ISSUES_URL" "$(printf '%s' "$title" | jq -sRr @uri)" "${C_RESET}"
  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1 && [[ -t 0 ]]; then
    local yn
    read -rp "  You're logged into GitHub — file this issue now with sanitized diagnostics attached? (y/N) " yn
    if [[ "$yn" =~ ^[Yy]$ ]]; then
      local body
      body="$(collect_repro)

## What failed

$summary

## Diagnostics

$(collect_diagnostics)

_Filed by the forge-deploy ${FORGE_DEPLOY_VERSION} recovery doctor._"
      if gh issue create -R "${REGISTRY_OWNER}/forge-deploy" --title "$title" --body "$body"; then
        ok "Issue filed — thank you."
      else
        warn "Auto-filing failed; please use the link above."
      fi
    fi
  fi
}

# Which of the core containers this box should run (scope-aware).
expected_containers() {
  local scoped_out c
  scoped_out=" $(env_get FORGE_SCOPED_OUT 2>/dev/null) "
  for c in "${CORE_CONTAINERS[@]}"; do
    [[ "$scoped_out" == *" $c "* ]] || printf '%s\n' "$c"
  done
}

# Scan the box for common failure modes, dependency order. Populates
# SCAN_HEAL / SCAN_FATAL; prints one line per finding.
bootstrap_scan() {
  SCAN_HEAL=(); SCAN_FATAL=()
  step "Checking this box"

  # 1. Docker installed at all?
  if ! command -v docker >/dev/null 2>&1; then
    scan_fatal "Docker is not installed. The README's 'Step 0 — OS prerequisites' has copy-paste install commands for your OS. Install it, then run: forge-deploy --recover"
    return 0
  fi
  ok "docker installed"

  # 2. Daemon running (and reachable by THIS user)?
  if ! docker info >/dev/null 2>&1; then
    if docker info 2>&1 | grep -qi "permission denied"; then
      scan_fatal "Docker is running but your user can't talk to it. Add yourself to the docker group — sudo usermod -aG docker \$USER — then log out and back in (or run 'newgrp docker'), and run: forge-deploy --recover"
    elif [[ "$(uname -s)" == "Linux" ]] && command -v systemctl >/dev/null 2>&1; then
      scan_heal daemon "Docker is installed but not running — will start it"
    else
      scan_fatal "Docker is installed but not running. Start Docker Desktop, wait for 'Docker Desktop is running', then run: forge-deploy --recover"
    fi
    return 0   # everything below needs the daemon
  fi
  ok "docker daemon running"

  # 3. snap-packaged Docker on cgroup v2: container teardown is broken.
  local droot dcg ddrv
  droot=$(docker info --format '{{.DockerRootDir}}' 2>/dev/null || true)
  dcg=$(docker info --format '{{.CgroupVersion}}' 2>/dev/null || true)
  ddrv=$(docker info --format '{{.CgroupDriver}}' 2>/dev/null || true)
  if [[ "$droot" == /var/snap/docker/* && "$dcg" == "2" && "$ddrv" == "systemd" ]]; then
    scan_fatal "This machine runs the snap-packaged Docker, which cannot stop or update containers on this OS (a known snap bug). Replace it with the standard packages — back up any Docker data first, 'snap remove' deletes it: sudo snap remove docker && sudo apt update && sudo apt install -y docker.io docker-compose-v2 — then run: forge-deploy --recover"
    return 0
  fi

  # 4. Compose v2 plugin?
  if ! docker compose version >/dev/null 2>&1; then
    scan_fatal "The Docker Compose plugin is missing. Ubuntu: sudo apt install docker-compose-v2 · other systems: see README 'Step 0'. Then run: forge-deploy --recover"
    return 0
  fi
  ok "compose v2 present"

  # 5. Deploy repo intact?
  if [[ ! -f "$COMPOSE_BASE" || ! -f "$COMPOSE_PROD" || ! -f "${REPO_ROOT}/.env.example" || ! -f "${REPO_ROOT}/setup.sh" ]]; then
    scan_fatal "The deploy folder at ${REPO_ROOT} is incomplete (missing compose/template files). Re-clone it: git clone https://github.com/armoryworks/forge-deploy.git — then run: forge-deploy --recover"
    return 0
  fi
  ok "deploy repo intact"

  # 6. CLI state installed? (heal: run the installer)
  if [[ ! -f "$STATE_FILE" || ! -w "$LOG_FILE" ]]; then
    scan_heal install "forge-deploy isn't fully installed on this box — will run the installer"
  fi

  # 7. .env — the bootstrap watershed. Absent → first-time setup.
  if [[ ! -f "$ENV_FILE" ]]; then
    scan_heal bootstrap "No configuration yet (.env missing) — first-time setup will run"
    return 0   # everything below reads .env
  fi
  ok ".env present"
  if [[ ! -w "$ENV_FILE" ]]; then
    scan_heal chown "Config files are owned by another user (usually a stray sudo) — will fix ownership"
  fi

  # 8. .env missing keys that .env.example has (repo moved on since setup ran).
  local missing
  missing=$(awk -F= 'NR==FNR { if ($0 ~ /^[A-Za-z_][A-Za-z0-9_]*=/) have[$1]=1; next }
                     /^[A-Za-z_][A-Za-z0-9_]*=/ && !($1 in have) { print $1 }' \
                     "$ENV_FILE" "${REPO_ROOT}/.env.example" 2>/dev/null || true)
  if [[ -n "$missing" ]]; then
    scan_heal envmerge "Config is missing newer settings ($(printf '%s' "$missing" | tr '\n' ' ' | cut -c1-50)…) — defaults will be added"
  fi

  # 9. JWT key never generated (login tokens would be forgeable/broken).
  local jwt
  jwt=$(env_get JWT_KEY)
  if [[ -z "$jwt" || "$jwt" == dev-secret-key-* || ${#jwt} -lt 32 ]]; then
    scan_heal jwt "Login signing key was never generated — will generate one"
  fi

  # 10. Image tags unset or floating 'latest'.
  local svc envvar tag
  for svc in $(box_service_ids); do
    envvar=$(service_envvar "$svc"); tag=$(env_get "$envvar")
    if [[ -z "$tag" || "$tag" == "latest" ]]; then
      scan_heal "pin:$svc" "No pinned version for '$svc' — will pin the newest release"
    fi
  done

  # 11. SSL override consistency. Two historical setup.sh bugs left installs
  # in these states; both are fully healable (see CHANGELOG 0.6.x).
  local override="${REPO_ROOT}/docker-compose.override.yml"
  if [[ -f "$override" ]] && grep -q '"443:443"' "$override"; then
    # 11a. Double-publish: base mapping also binding host 443 via UI_PORT.
    if [[ "$(env_get UI_PORT)" == "443" ]]; then
      scan_heal sslports "Host port 443 is claimed twice (UI_PORT=443 plus the SSL override) — will move the plain-HTTP mapping back to loopback:4200"
    fi
    # 11b. Phantom directory where the TLS nginx config file must be.
    local sslconf="${REPO_ROOT}/forge-ui/nginx-ssl.conf"
    if [[ -d "$sslconf" || ! -f "$sslconf" ]]; then
      scan_heal sslconf "The TLS nginx config is missing or was auto-created as an empty directory by docker — will restore the real file"
    fi
  fi

  # 12. Container states for this box's components.
  local c state needs_up=false
  for c in $(expected_containers); do
    state=$(docker inspect --format '{{.State.Status}}' "$c" 2>/dev/null || echo absent)
    case "$state" in
      running) ;;
      restarting)
        scan_heal "recreate:$c" "'$c' is stuck in a restart loop — will recreate it" ;;
      *)
        needs_up=true ;;
    esac
  done
  if $needs_up; then
    scan_heal up "Some services are stopped or were never started — will bring them up"
  elif (( ${#SCAN_HEAL[@]} == 0 )); then
    ok "all expected services running"
  fi
}

# Read the api container's log and translate known failure signatures into
# plain language. Returns 0 if it identified (and printed) a cause.
diagnose_api() {
  local logs
  logs=$(docker logs forge-api --tail 80 2>&1 || true)
  if grep -qiE 'password authentication failed' <<<"$logs"; then
    err "The app can't log in to its database — the database password in ${ENV_FILE} doesn't match the one the database was created with."
    err "If this install has no data you care about yet, the simplest fix is a clean restart: forge-deploy --fresh-start"
    return 0
  fi
  if grep -qiE 'connection refused|no such host|name or service not known' <<<"$logs"; then
    err "The app can't reach its database or storage. If they run on another box, check that box is up and reachable (forge-deploy --status there), then re-run: forge-deploy --recover"
    return 0
  fi
  if grep -qiE 'unauthorized|denied.*ghcr|pull access denied' <<<"$logs"; then
    err "The prebuilt images couldn't be downloaded (registry says 'unauthorized'). Log in first: docker login ghcr.io -u <your-github-username> (use a token with the read:packages scope as the password), then re-run: forge-deploy --recover"
    return 0
  fi
  return 1
}

run_bootstrap() {
  local flags=() yn
  if [[ -t 0 ]]; then
    read -rp "  Load demo data (sample users/jobs/customers — good for a first look)? (y/N) " yn
    [[ "$yn" =~ ^[Yy]$ ]] && flags+=(--seeded)
  fi
  ( cd "$REPO_ROOT" && FORGE_DEPLOY_CALLER=1 bash ./setup.sh "${flags[@]}" )
}

pin_newest() {
  local svc="$1" repo newest
  repo=$(service_repo "$svc")
  newest=$(ghcr_list_tags "$repo" 2>/dev/null | grep -E "$TAG_RE_SEMVER" | sort -V | tail -1 || true)
  if [[ -z "$newest" ]]; then
    err "Couldn't list released versions for '$svc'. If the registry needs a login: docker login ghcr.io -u <your-github-username> (token with read:packages), then re-run: forge-deploy --recover"
    return 1
  fi
  env_set "$(service_envvar "$svc")" "$newest"
  ok "$svc pinned to $newest"
}

# Bring the box up, translating the most common `up` failure (port conflict)
# into a plain-language action instead of a compose stack trace.
heal_up() {
  local out rc=0
  out=$(cmd_up 2>&1) || rc=$?
  printf '%s\n' "$out" | tail -3
  if (( rc != 0 )) && grep -qiE 'port is already allocated|address already in use' <<<"$out"; then
    local port
    port=$(grep -oE '[0-9]+' <<<"$(grep -ioE '(0\.0\.0\.0|127\.0\.0\.1|\[::\]):[0-9]+' <<<"$out" | head -1)" | tail -1)
    scan_fatal "Port ${port:-(unknown)} is already used by another program on this machine. Either stop that program, or change UI_PORT / API_PORT in ${ENV_FILE} and run: forge-deploy --recover. (Don't kill 'docker-proxy' processes blindly — they may belong to another app.)"
    return 1
  fi
  return $rc
}

apply_heal() {
  case "$1" in
    daemon)     sudo systemctl start docker ;;
    install)    sudo bash "${REPO_ROOT}/scripts/install-forge-deploy.sh" ;;
    bootstrap)  run_bootstrap ;;
    chown)      sudo chown -R "$(id -un):$(id -gn)" "$REPO_ROOT" ;;
    envmerge)
      local k
      while IFS= read -r k; do
        [[ -n "$k" ]] || continue
        env_set "$k" "$(grep -E "^${k}=" "${REPO_ROOT}/.env.example" | head -1 | cut -d= -f2-)"
      done < <(awk -F= 'NR==FNR { if ($0 ~ /^[A-Za-z_][A-Za-z0-9_]*=/) have[$1]=1; next }
                        /^[A-Za-z_][A-Za-z0-9_]*=/ && !($1 in have) { print $1 }' \
                        "$ENV_FILE" "${REPO_ROOT}/.env.example")
      ok "added missing settings from .env.example defaults"
      ;;
    jwt)        env_set JWT_KEY "$(head -c 256 /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 48)"; ok "generated login signing key" ;;
    sslports)
      env_set UI_PORT 4200
      env_set UI_BIND 127.0.0.1
      ok "UI_PORT=4200, UI_BIND=127.0.0.1 — the SSL override now solely owns host 443/80"
      ;;
    sslconf)
      local sslconf="${REPO_ROOT}/forge-ui/nginx-ssl.conf"
      # Phantom empty dir docker auto-created for the bind mount — remove it.
      if [[ -d "$sslconf" ]]; then
        rmdir "$sslconf" 2>/dev/null || sudo rmdir "$sslconf" 2>/dev/null || return 1
      fi
      # The real file is tracked in this repo; restore it from git if absent.
      if [[ ! -f "$sslconf" ]]; then
        git -C "$REPO_ROOT" checkout -- forge-ui/nginx-ssl.conf 2>/dev/null || true
      fi
      if [[ -f "$sslconf" ]]; then
        ok "restored TLS nginx config: forge-ui/nginx-ssl.conf"
      else
        err "forge-ui/nginx-ssl.conf is not in this checkout — update it: git -C ${REPO_ROOT} pull — then re-run: forge-deploy --recover"
        return 1
      fi
      ;;
    pin:*)      pin_newest "${1#pin:}" ;;
    recreate:*) compose up -d --force-recreate "${1#recreate:}" ;;
    up)         heal_up ;;
    *)          return 1 ;;
  esac
}

# The doctor. Scan → offer resume-vs-fresh → heal → rescan (≤3 passes) →
# health-gate. Unknown terminal states route to report_unrecoverable.
cmd_recover() {
  require_cmd jq; require_cmd curl
  printf '\n%s== forge-deploy recovery ==%s\n' "${C_BOLD}${C_CYAN}" "${C_RESET}"
  local pass=1 asked=false
  while (( pass <= 3 )); do
    bootstrap_scan
    trace "Doctor scan pass ${pass}: fixable=[${SCAN_HEAL[*]:-none}], needs-user=${#SCAN_FATAL[@]}."
    if (( ${#SCAN_FATAL[@]} > 0 )); then
      printf '\n%sFix the item(s) above, then run:%s forge-deploy --recover\n' "${C_BOLD}" "${C_RESET}"
      return 1
    fi
    (( ${#SCAN_HEAL[@]} == 0 )) && break
    if ! $asked && [[ -t 0 ]]; then
      asked=true
      printf '\nFound %d fixable item(s). You can:\n' "${#SCAN_HEAL[@]}"
      printf '  r) resume — fix in place and keep your data (default)\n'
      printf '  f) fresh start — wipe EVERYTHING (database, files, config) and set up from scratch\n'
      printf '  q) quit\n'
      local c; read -rp 'Choose [r/f/q]: ' c
      case "$c" in
        f|F) cmd_fresh_start; return $? ;;
        q|Q) return 0 ;;
      esac
    fi
    local h healed_all=true
    for h in "${SCAN_HEAL[@]}"; do
      if apply_heal "$h"; then
        trace "Auto-fix '$h': succeeded."
      else
        trace "Auto-fix '$h': FAILED."
        healed_all=false
      fi
    done
    if ! $healed_all && (( pass == 3 )); then break; fi
    (( pass++ ))
  done

  # Post-heal: if this box runs the API, gate on its health before declaring victory.
  if [[ -f "$ENV_FILE" ]] && expected_containers | grep -qx forge-api; then
    step "Waiting for the app to come up (first start can take a few minutes)"
    trace "Waited for forge-api health (timeout $(health_timeout)s)."
    if wait_healthy api; then
      local ui_port api_port
      ui_port=$(env_get UI_PORT); api_port=$(env_get API_PORT)
      printf '\n%s✓ Forge is up.%s  Web app: http://localhost:%s  ·  API health: http://localhost:%s/api/v1/health\n' \
        "${C_GREEN}${C_BOLD}" "${C_RESET}" "${ui_port:-4200}" "${api_port:-5000}"
    else
      trace "forge-api never reported healthy; log signatures matched no known cause."
      diagnose_api || report_unrecoverable \
        "recovery: forge-api won't become healthy" \
        "Setup mostly completed, but the app never reported healthy and the logs don't match a known cause. Your data has not been touched. You can retry with 'forge-deploy --recover', or start over with 'forge-deploy --fresh-start'."
      return 1
    fi
  fi

  # A healthy but never-configured box flows straight into the topology wizard.
  local role=""
  [[ -f "$STATE_FILE" ]] && role=$(jq -r '.box.role // ""' "$STATE_FILE" 2>/dev/null || echo "")
  if [[ -z "$role" && -f "$ENV_FILE" && -t 0 ]]; then
    SETUP_ROLE=""; cmd_setup
  fi
}

# Destructive reset: containers, volumes (database + uploaded files), and
# generated config — then a from-scratch setup. Typed confirmation required.
cmd_fresh_start() {
  [[ -t 0 ]] || die "--fresh-start needs an interactive terminal (it requires typed confirmation)"
  printf '\n%s== FRESH START — this deletes data ==%s\n' "${C_BOLD}${C_RED}" "${C_RESET}"
  warn "This permanently removes on THIS box:"
  warn "  - all Forge containers"
  warn "  - the database and every uploaded file (volumes: pgdata, miniodata, …)"
  warn "  - generated config (.env, certs/, compose overrides, box scope)"
  printf 'Type FRESH to confirm (anything else aborts): '
  local c; read -r c
  [[ "$c" == "FRESH" ]] || { warn "Aborted — nothing was changed."; return 1; }

  step "Tearing down"
  if [[ -f "$ENV_FILE" ]]; then
    compose down --volumes --remove-orphans 2>/dev/null || true
  fi
  # Belt-and-braces for broken/partial states where compose can't resolve.
  docker rm -f forge forge-storage forge-backup forge-api forge-ui forge-test forge-demo \
    forge-ai forge-ai-init forge-tts forge-logs forge-signing forge-api-proxy 2>/dev/null || true
  docker volume ls -q --filter "name=$(basename "$REPO_ROOT")" 2>/dev/null | xargs -r docker volume rm 2>/dev/null || true

  rm -f "$ENV_FILE" "${REPO_ROOT}/docker-compose.override.yml" "$COMPOSE_SCOPE" "$COMPOSE_REMOTE_API" "$REMOTE_API_CONF"
  rm -rf "${REPO_ROOT}/certs"
  if [[ -f "$STATE_FILE" && -w "$STATE_FILE" ]]; then
    local tmp; tmp=$(mktemp)
    jq 'del(.box)' "$STATE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$STATE_FILE" || rm -f "$tmp"
  fi
  ok "Clean slate"
  trace "Fresh start: tore down containers/volumes and removed generated config."

  step "Running first-time setup"
  if ! run_bootstrap; then
    trace "From-scratch bootstrap (setup.sh) exited non-zero on a clean slate."
    report_unrecoverable "fresh start: setup failed" \
      "A from-scratch setup still failed on this machine, so the problem is likely environmental (Docker install, network, or registry access) rather than leftover state."
    return 1
  fi
  SETUP_ROLE=""; cmd_setup
}

# ── Interactive per-component version picker + reset ─────────────────────────

# Echo "semver<TAB>sha" rows for a repo's recent versions, oldest->newest.
# Pairs each X.Y.Z with its main-<sha> build (they share a manifest digest).
version_sha_rows() {
  local repo="$1" limit="${2:-12}" tags versions shas
  tags=$(ghcr_list_tags "$repo" 2>/dev/null || true)
  versions=$(printf '%s\n' "$tags" | grep -E '^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z.]+)?$' | sort -V | tail -"$limit" || true)
  [[ -z "$versions" ]] && return 0
  shas=$(printf '%s\n' "$tags" | grep -E '^main-[a-f0-9]+$' || true)
  ghcr_token "$repo" >/dev/null 2>&1 || true
  export REGISTRY_HOST REGISTRY_OWNER STATE_DIR
  export -f ghcr_manifest_digest ghcr_token ghcr_basic_creds
  local ver_d sha_d
  ver_d=$(printf '%s\n' "$versions" | xargs -P 8 -I{} bash -c 'd=$(ghcr_manifest_digest "$0" "$1"); [[ -n "$d" ]] && printf "%s\t%s\n" "$1" "$d"' "$repo" {} 2>/dev/null || true)
  sha_d=$(printf '%s\n' "$shas" | xargs -P 8 -I{} bash -c 'd=$(ghcr_manifest_digest "$0" "$1"); [[ -n "$d" ]] && printf "%s\t%s\n" "$1" "$d"' "$repo" {} 2>/dev/null || true)
  local -A sha_by_d; local tag dg
  while IFS=$'\t' read -r tag dg; do [[ -n "$dg" ]] && sha_by_d["$dg"]="$tag"; done <<<"$sha_d"
  local v
  while IFS=$'\t' read -r v dg; do
    [[ -z "$v" ]] && continue
    printf '%s\t%s\n' "$v" "${sha_by_d[$dg]:-}"
  done <<<"$ver_d"
}

# Interactive version chooser for ONE component. Renders the version list to
# stderr (oldest->newest, current marked with » «, default highlighted), reads a
# choice, and ECHOES the chosen semver to stdout. Default (Enter) = current if
# set, else newest. Return: 0 chosen/kept, 10 = re-setup hotkey, 20 = quit.
pick_component_version() {
  local svc_id="$1" repo current rows cur_ver newest
  repo=$(service_repo "$svc_id")
  current=$(state_get "$repo" current 2>/dev/null || true)
  [[ -z "$current" ]] && current=$(env_get "$(service_envvar "$svc_id")" 2>/dev/null || true)
  printf '\n%s%s%s  (current: %s)\n' "${C_CYAN}${C_BOLD}" "$svc_id" "${C_RESET}" "${current:-<none>}" >&2

  rows=$(version_sha_rows "$repo" 12)
  if [[ -z "$rows" ]]; then
    printf '  %s(no published versions found in GHCR)%s\n' "${C_DIM}" "${C_RESET}" >&2
    return 0
  fi

  # current semver = a row whose semver OR paired sha equals the deployed tag
  cur_ver=""
  local v s
  while IFS=$'\t' read -r v s; do
    [[ "$v" == "$current" || ( -n "$s" && "$s" == "$current" ) ]] && cur_ver="$v"
  done <<<"$rows"

  local -a vers=(); local i=1 mark note default_ver
  while IFS=$'\t' read -r v s; do
    [[ -z "$v" ]] && continue
    vers+=("$v"); newest="$v"
    mark="   "; note=""
    if [[ -n "$cur_ver" && "$v" == "$cur_ver" ]]; then
      mark="${C_GREEN}»${C_RESET}  "; note="  ${C_GREEN}« current${C_RESET}"
    fi
    printf '  %s%s[%d]%s %-10s %s(%s)%s%s\n' "$mark" "${C_BOLD}" "$i" "${C_RESET}" "$v" "${C_DIM}" "${s:-?}" "${C_RESET}" "$note" >&2
    i=$((i+1))
  done <<<"$rows"

  default_ver="${cur_ver:-$newest}"
  [[ -z "$cur_ver" ]] && printf '  %s(default: newest %s)%s\n' "${C_DIM}" "$newest" "${C_RESET}" >&2
  printf '  Choose [Enter=%s, 1-%d, %sr%s=re-setup, %sq%s=quit]: ' \
    "$default_ver" "${#vers[@]}" "${C_BOLD}" "${C_RESET}" "${C_BOLD}" "${C_RESET}" >&2
  local choice; read -r choice
  case "$choice" in
    "")    printf '%s' "$default_ver"; return 0 ;;
    r|R)   return 10 ;;
    q|Q)   return 20 ;;
    *)
      if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#vers[@]} )); then
        printf '%s' "${vers[$((choice-1))]}"; return 0
      fi
      printf '  %sinvalid choice — keeping %s%s\n' "${C_YELLOW}" "$default_ver" "${C_RESET}" >&2
      printf '%s' "$default_ver"; return 0 ;;
  esac
}

# Default bare `forge-deploy` on a CONFIGURED box: walk each component, pick a
# version (Enter keeps current), deploy only the ones that changed.
cmd_update_interactive() {
  preflight
  printf '\n%sUpdate — %s%s\n' "${C_BOLD}" "$(box_scope_label)" "${C_RESET}"
  printf '%sEnter keeps the current version · number selects · r re-runs setup · q quits%s\n' "${C_DIM}" "${C_RESET}"
  local svc_id rc chosen current_tag
  for svc_id in $(box_service_ids); do
    rc=0; chosen=$(pick_component_version "$svc_id") || rc=$?
    if (( rc == 10 )); then cmd_reset; return; fi
    if (( rc == 20 )); then ok "Stopped — no further changes."; return; fi
    [[ -z "$chosen" ]] && continue
    current_tag=$(state_get "$(service_repo "$svc_id")" current 2>/dev/null || true)
    if [[ "$chosen" == "$current_tag" ]]; then
      ok "$svc_id kept at $chosen"
    else
      validate_tag "$chosen"
      deploy_service "$svc_id" "$chosen" || warn "$svc_id deploy failed (see $LOG_FILE)"
    fi
  done
  ok "All components reviewed."
}

# Full reset for this box's components, then re-run setup. Strongly gated:
# data volumes are preserved unless the operator explicitly types WIPE.
cmd_reset() {
  printf '\n%s== RE-SETUP (reset this box) ==%s\n' "${C_RED}${C_BOLD}" "${C_RESET}"
  printf 'Removes the containers + pinned images for this box (%s), clears its\n' "$(box_scope_label)"
  printf 'scope/wiring settings, and re-runs the topology wizard from scratch.\n'
  printf '%sData volumes (Postgres, MinIO) are KEPT unless you opt in below.%s\n\n' "${C_DIM}" "${C_RESET}"
  printf 'Also WIPE data volumes (DESTROYS the database + stored files, irreversible)?\n'
  printf '  type %sWIPE%s to wipe, or press Enter to keep data: ' "${C_RED}${C_BOLD}" "${C_RESET}"
  local wipe; read -r wipe
  printf 'Proceed with re-setup%s? [y/N]: ' "$([[ "$wipe" == "WIPE" ]] && printf ' %s+ DATA WIPE%s' "${C_RED}" "${C_RESET}")"
  local go; read -r go
  [[ "$go" == "y" || "$go" == "Y" || "$go" == "yes" ]] || { warn "Cancelled — nothing changed."; return 0; }

  step "Stopping + removing containers"
  if [[ "$wipe" == "WIPE" ]]; then compose down -v --remove-orphans || true; else compose down --remove-orphans || true; fi

  step "Removing pinned images"
  local svc_id repo tag
  for svc_id in $(box_service_ids); do
    repo=$(service_repo "$svc_id"); tag=$(env_get "$(service_envvar "$svc_id")" 2>/dev/null || true)
    [[ -n "$tag" && "$tag" != "latest" ]] && docker rmi "${REGISTRY_HOST}/${REGISTRY_OWNER}/${repo}:${tag}" 2>/dev/null || true
  done

  step "Clearing box settings"
  rm -f "$COMPOSE_SCOPE" "$COMPOSE_REMOTE_API" "$REMOTE_API_CONF"
  local tmp; tmp=$(mktemp)
  grep -vE '^(FORGE_SCOPED_OUT|FORGE_DEPLOY_SERVICES|DB_HOST|DB_PORT|MINIO_ENDPOINT)=' "$ENV_FILE" > "$tmp" && mv "$tmp" "$ENV_FILE"
  local cf; cf=$(env_get COMPOSE_FILE 2>/dev/null || true)
  [[ -n "$cf" ]] && env_set COMPOSE_FILE "$(printf '%s' "$cf" | sed 's/:docker-compose\.scope\.yml//g; s/:docker-compose\.remote-api\.yml//g')"
  tmp=$(mktemp); jq 'del(.box)' "$STATE_FILE" > "$tmp" 2>/dev/null && mv "$tmp" "$STATE_FILE" || rm -f "$tmp"
  ok "Settings cleared"

  step "Re-running setup"
  SETUP_ROLE=""; cmd_setup
}

cmd_self_update() {
  step "Self-update: $REPO_ROOT"
  if [[ ! -d "${REPO_ROOT}/.git" ]]; then
    die "Not a git checkout: $REPO_ROOT"
  fi
  # Only refuse on tracked-file modifications. Untracked operator files
  # (.env, override.yml) are gitignored upstream but older Pi installs may
  # still have them present and unignored — they shouldn't block self-update.
  if ! git -C "$REPO_ROOT" diff --quiet HEAD -- 2>/dev/null; then
    die "Local changes to tracked files present in $REPO_ROOT — refusing to pull"
  fi
  git -C "$REPO_ROOT" pull --ff-only
  ok "Pulled latest"
  if [[ -x "${REPO_ROOT}/scripts/install-forge-deploy.sh" ]]; then
    "${REPO_ROOT}/scripts/install-forge-deploy.sh"
  else
    warn "install-forge-deploy.sh not found or not executable"
  fi
}

# Interactive tag picker for one image. Echoes the chosen tag.
pick_tag_interactive() {
  local svc_id="$1"
  local repo
  repo=$(service_repo "$svc_id")
  local tags
  tags=$(ghcr_list_tags "$repo" 2>/dev/null | grep -E '^main-[a-f0-9]+$' | sort -r | head -5 || true)
  if [[ -z "$tags" ]]; then
    die "No main-<sha> tags available for $repo"
  fi
  printf '\nRecent builds for %s:\n' "$repo" >&2
  local i=1
  local tag_array=()
  while IFS= read -r t; do
    [[ -z "$t" ]] && continue
    tag_array+=("$t")
    printf '  [%d] %s\n' "$i" "$t" >&2
    i=$(( i + 1 ))
  done <<<"$tags"
  printf '\nChoose [1-%d] (or Enter for 1, q to cancel): ' "${#tag_array[@]}" >&2
  local choice
  read -r choice
  if [[ "$choice" == "q" || "$choice" == "Q" ]]; then
    die "Cancelled by user"
  fi
  choice="${choice:-1}"
  if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#tag_array[@]} )); then
    die "Invalid choice: $choice"
  fi
  printf '%s\n' "${tag_array[$(( choice - 1 ))]}"
}

# ─────────────────────────────────────────────────────────────
# Schema reconcile (forge-db)
# ─────────────────────────────────────────────────────────────
# Applies the pinned forge-db schema to the LIVE database before the forge-api
# image is swapped, so the schema reaches the new version's expectations (the
# app's own SchemaBootstrapper is a no-op on an existing DB). Off by default;
# enable per box with ENABLE_SCHEMA_RECONCILE=true + SCHEMA_IMAGE_TAG=<tag>.
# Additive changes auto-apply after a fresh backup; destructive changes HALT and
# are enumerated for operator disposition unless --allow-destructive is passed.

# The docker network the live 'forge' postgres container is on, so the one-shot
# forge-db container can reach it by service name.
reconcile_network() {
  local cid
  cid=$(compose ps -q forge 2>/dev/null || true)
  [[ -n "$cid" ]] || return 1
  docker inspect "$cid" \
    --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}' 2>/dev/null \
    | awk '{print $1}'
}

reconcile_db_url() {
  local h p d u w
  h=$(env_get DB_HOST);            h="${h:-forge}"
  p=$(env_get DB_PORT);            p="${p:-5432}"
  d=$(env_get POSTGRES_DB);        d="${d:-forge}"
  u=$(env_get POSTGRES_USER);      u="${u:-postgres}"
  w=$(env_get POSTGRES_PASSWORD);  w="${w:-postgres}"
  printf 'postgres://%s:%s@%s:%s/%s' "$u" "$w" "$h" "$p" "$d"
}

# Run a forge-db verb in a one-shot container on the DB network.
#   reconcile_forge_db <net> <image> <verb> [extra args...]
reconcile_forge_db() {
  local net="$1" image="$2"; shift 2
  docker run --rm --network "$net" "$image" "$@" --db "$(reconcile_db_url)"
}

# Pull destructive DDL out of a `forge-db plan` rendering and present it numbered
# for the operator's disposition (the agreed ok-to-drop / can't-until / cannot form).
enumerate_destructive() {
  local plan_text="$1" n=0 line
  warn "Destructive changes requiring your disposition:"
  while IFS= read -r line; do
    if printf '%s' "$line" | grep -qiE '\bDROP[[:space:]]+(TABLE|COLUMN|CONSTRAINT|INDEX|VIEW|SCHEMA|TYPE|SEQUENCE)\b|\bDROP[[:space:]]+NOT[[:space:]]+NULL\b|ALTER[[:space:]]+COLUMN[[:space:]].*[[:space:]]TYPE[[:space:]]'; then
      n=$((n+1))
      printf '      %s%d%s - %s\n' "${C_RED}" "$n" "${C_RESET}" "$(printf '%s' "$line" | sed 's/^[[:space:]]*//')"
    fi
  done <<< "$plan_text"
  (( n == 0 )) && printf '      (see the forge-db output above for the flagged statements)\n'
  printf '\n      For each, reply: 1 - ok to delete / 2 - cannot until x,y,z / 3 - cannot delete\n'
}

# Reconcile the live schema before the app swap. Returns 0 to proceed, 1 to abort.
reconcile_schema() {
  local enabled schema_tag net image
  enabled=$(env_get ENABLE_SCHEMA_RECONCILE | tr -d '[:space:]')
  if [[ "$enabled" != "true" ]]; then
    ok "Schema reconcile disabled (ENABLE_SCHEMA_RECONCILE != true) — skipping"
    return 0
  fi

  # Split topology: on a remote-DB api box the 'forge' postgres container is on
  # the db box, not this compose network — reconcile there. Skip (don't fail) so
  # the api deploy proceeds; the db box owns schema apply. Local (DB_HOST unset
  # or 'forge') is unchanged and still reconciles.
  local dbh; dbh=$(env_get DB_HOST | tr -d '[:space:]')
  if [[ -n "$dbh" && "$dbh" != "forge" ]]; then
    warn "DB is remote (${dbh}) — schema apply must run on the DB box; skipping reconcile here"
    return 0
  fi

  schema_tag=$(env_get SCHEMA_IMAGE_TAG | tr -d '[:space:]')
  if [[ -z "$schema_tag" ]]; then
    err "ENABLE_SCHEMA_RECONCILE=true but SCHEMA_IMAGE_TAG is not set in .env"
    return 1
  fi
  image="${REGISTRY_HOST}/${REGISTRY_OWNER}/forge-db:${schema_tag}"

  net=$(reconcile_network) || true
  if [[ -z "$net" ]]; then
    err "Could not find the DB container network (is the 'forge' service running?)"
    return 1
  fi

  step "Schema reconcile (forge-db ${schema_tag})"

  step "  Taking a fresh pre-reconcile backup"
  if ! compose exec -T forge-backup /usr/local/bin/backup.sh; then
    err "Pre-reconcile backup failed — aborting (nothing applied, app NOT swapped)"
    return 1
  fi
  ok "Backup complete"

  docker pull "$image" >/dev/null 2>&1 || true

  local allow="${ALLOW_DESTRUCTIVE:-false}" out rc=0
  step "  Applying schema"
  out=$(reconcile_forge_db "$net" "$image" apply --env prod --yes --backup-taken 2>&1) || rc=$?
  printf '%s\n' "$out" | sed 's/^/      /'

  if (( rc == 0 )); then
    ok "Schema reconciled (additive / already in sync)"
    return 0
  fi

  # Exit 3 = DeployGates blocked a destructive plan (forge-db ApplyCommand).
  if (( rc == 3 )); then
    if [[ "$allow" == "true" ]]; then
      warn "Destructive changes present — re-applying with --allow-destructive (operator-approved)"
      if reconcile_forge_db "$net" "$image" apply --env prod --yes --backup-taken --allow-destructive; then
        ok "Schema reconciled (destructive changes applied with approval)"
        return 0
      fi
      err "Apply failed even with --allow-destructive — aborting"
      return 1
    fi
    err "DESTRUCTIVE schema changes detected — deploy HALTED. Nothing applied; app NOT swapped."
    printf '\n'
    enumerate_destructive "$(reconcile_forge_db "$net" "$image" plan 2>&1 || true)"
    printf '\n'
    err "Re-run the deploy with --allow-destructive once the items above are dispositioned."
    return 1
  fi

  err "Schema reconcile failed (forge-db exit ${rc}) — aborting before the app swap"
  return 1
}

# Deploy a single service to a single tag.
deploy_service() {
  local svc_id="$1" target_tag="$2"
  local repo envvar compose_svc prior_tag
  repo=$(service_repo "$svc_id")
  envvar=$(service_envvar "$svc_id")
  compose_svc=$(service_compose "$svc_id")
  # Prefer the state file's `current` (last successful deploy) as the rollback
  # target. The .env value is a snapshot of what's CONFIGURED, which can
  # diverge from what's RUNNING if an operator hand-edited .env between
  # deploys (e.g. set everything to 0.0.0 as a placeholder). Falling back to
  # .env preserves first-deploy-ever semantics where state is empty.
  prior_tag=$(state_get "$repo" current)
  if [[ -z "$prior_tag" ]]; then
    prior_tag=$(env_get "$envvar")
  fi

  step "Deploying $svc_id -> $target_tag"

  # Split topology: an api box with a remote DB must be able to reach it before
  # we pull/recreate. Fail fast + non-destructively (nothing swapped yet). A
  # no-op for local DB, so single-box/api+db deploys are unchanged.
  if [[ "$svc_id" == "api" ]]; then
    if ! check_remote_reachable; then
      err "Remote DB/MinIO unreachable — aborting before touching the running app"
      log_event "$svc_id" "$prior_tag" "$target_tag" "remote-db-unreachable"
      return 1
    fi
  fi

  if ! ghcr_tag_exists "$repo" "$target_tag"; then
    err "Tag not found in GHCR: ${REGISTRY_OWNER}/${repo}:${target_tag}"
    log_event "$svc_id" "$prior_tag" "$target_tag" "missing-in-ghcr"
    return 1
  fi
  ok "Tag verified in GHCR"

  env_set "$envvar" "$target_tag"
  ok ".env updated: ${envvar}=${target_tag}"

  if ! compose pull "$compose_svc"; then
    err "docker compose pull failed"
    env_set "$envvar" "$prior_tag"
    log_event "$svc_id" "$prior_tag" "$target_tag" "pull-failed"
    return 1
  fi
  ok "Image pulled"

  # Reconcile the live DB schema to the pinned forge-db BEFORE swapping the app
  # (api only). A halt (destructive) or failure reverts the .env pin and returns
  # without ever recreating the container — the running app and DB are untouched.
  if [[ "$svc_id" == "api" ]]; then
    if ! reconcile_schema; then
      env_set "$envvar" "$prior_tag"
      log_event "$svc_id" "$prior_tag" "$target_tag" "schema-reconcile-failed"
      return 1
    fi
  fi

  # --force-recreate: a previous failed `up -d` (e.g. port collision) can
  # leave a container in a half-started state without published port
  # bindings. Subsequent `up -d` runs see "config matches" and refuse to
  # recreate. Forcing recreate every time guarantees fresh container with
  # the merged config's port mappings actually applied. Cost: 2-5s per svc.
  if ! compose up -d --force-recreate "$compose_svc"; then
    err "docker compose up -d failed"
    env_set "$envvar" "$prior_tag"
    compose up -d --force-recreate "$compose_svc" || true
    log_event "$svc_id" "$prior_tag" "$target_tag" "up-failed"
    return 1
  fi
  ok "Container started"

  step "Waiting for healthy ($(health_timeout) s max)"
  if wait_healthy "$svc_id"; then
    ok "Service healthy"
    state_set "$repo" "$target_tag"
    log_event "$svc_id" "$prior_tag" "$target_tag" "ok"
    return 0
  fi

  err "Service did not become healthy — rolling back to $prior_tag"
  if [[ -n "$prior_tag" && "$prior_tag" != "$target_tag" ]]; then
    env_set "$envvar" "$prior_tag"
    compose up -d --force-recreate "$compose_svc" || true
  fi
  log_event "$svc_id" "$prior_tag" "$target_tag" "unhealthy-rolled-back"
  return 1
}

cmd_deploy() {
  local target_services=("$@")  # space-separated svc_ids
  local explicit_tag="${EXPLICIT_TAG:-}"

  local svc_id
  local failed=0
  for svc_id in "${target_services[@]}"; do
    local tag
    if [[ -n "$explicit_tag" ]]; then
      tag="$explicit_tag"
    else
      tag=$(pick_tag_interactive "$svc_id")
    fi
    validate_tag "$tag"
    if ! deploy_service "$svc_id" "$tag"; then
      failed=1
    fi
  done

  if (( failed )); then
    err "One or more services failed to deploy — check $LOG_FILE"
    exit 1
  fi
  ok "All targeted services deployed successfully"
}

cmd_rollback() {
  local svc_id="${1:-all}"
  local target_services
  if [[ "$svc_id" == "all" ]]; then
    mapfile -t target_services < <(box_service_ids)
  else
    if ! service_repo "$svc_id" >/dev/null 2>&1; then
      die "Unknown service: $svc_id"
    fi
    if ! box_service_ids | grep -qx "$svc_id"; then
      die "Service '$svc_id' is not a component on this box (runs: $(box_scope_label))."
    fi
    target_services=("$svc_id")
  fi
  local failed=0
  for svc_id in "${target_services[@]}"; do
    local repo prior
    repo=$(service_repo "$svc_id")
    prior=$(state_get "$repo" prior)
    if [[ -z "$prior" ]]; then
      warn "No prior tag recorded for $svc_id — skipping"
      continue
    fi
    step "Rollback $svc_id -> $prior"
    if ! deploy_service "$svc_id" "$prior"; then
      failed=1
    fi
  done
  if (( failed )); then exit 1; fi
}

# ─────────────────────────────────────────────────────────────
# Argument parsing
# ─────────────────────────────────────────────────────────────

parse_service_arg() {
  # Echoes one or more svc_ids, constrained to this box's component scope.
  local arg="$1"
  if [[ "$arg" == "all" ]]; then
    box_service_ids
    return
  fi
  # Unknown ids are a typo; reject. Valid ids derive from SERVICES, so a new
  # service (e.g. demo) is accepted here automatically.
  if ! all_service_ids | grep -qx "$arg"; then
    die "Unknown --service value: $arg (valid: $(all_service_ids | tr '\n' ' ')all)"
  fi
  # Reject services this box doesn't run, so the API box can't accidentally
  # deploy the UI/demo (and vice-versa). Declare scope via FORGE_DEPLOY_SERVICES.
  if box_service_ids | grep -qx "$arg"; then
    printf '%s\n' "$arg"
  else
    die "Service '$arg' is not a component on this box (runs: $(box_scope_label)). Set FORGE_DEPLOY_SERVICES in .env (or: forge-deploy --components $arg) to change."
  fi
}

main() {
  if [[ $# -eq 0 ]]; then
    # No args: never-bootstrapped box -> recovery doctor (detects the state,
    #          runs first-time setup or resumes a broken one);
    #          first run (no role yet) -> topology setup wizard;
    #          configured box          -> per-component version picker.
    if [[ ! -f "$ENV_FILE" || ! -f "$STATE_FILE" ]]; then
      cmd_recover
      return
    fi
    preflight
    local configured_role=""
    [[ -f "$STATE_FILE" ]] && configured_role=$(jq -r '.box.role // ""' "$STATE_FILE" 2>/dev/null || echo "")
    if [[ -n "$configured_role" ]]; then
      cmd_update_interactive
    else
      cmd_setup
    fi
    return
  fi

  # `compose` subcommand: everything after it is passed verbatim to the
  # scope-aware compose wrapper. Handle before flag parsing so flags like
  # `-f` / `--profile` aren't intercepted as forge-deploy options.
  if [[ "${1:-}" == "compose" ]]; then
    shift
    cmd_compose "$@"
    return
  fi

  local mode="" service_arg="" positional="" components_val="" remote_api_val="" remote_db_val=""
  # list_mode: combined (default — version + build-sha paired) | releases | builds
  local list_mode="combined"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --help|-h)         usage; exit 0 ;;
      --version|-V)      printf 'forge-deploy %s\n' "$FORGE_DEPLOY_VERSION"; exit 0 ;;
      --list)            mode="list"; shift ;;
      --releases)        list_mode="releases"; shift ;;
      --builds)          list_mode="builds"; shift ;;
      --status)          mode="status"; shift ;;
      --rollback)        mode="rollback"; shift ;;
      --logs)            mode="logs"; shift ;;
      --components)
        mode="components"
        if [[ $# -ge 2 && "$2" != -* ]]; then components_val="$2"; shift 2; else shift; fi
        ;;
      --wizard)          mode="wizard"; shift ;;
      --up|--start)      mode="up"; shift ;;
      --setup)           mode="setup"; shift ;;
      --role)            [[ $# -ge 2 ]] || die "--role needs a value"; SETUP_ROLE="$2"; shift 2 ;;
      --api-url)         [[ $# -ge 2 ]] || die "--api-url needs a value"; SETUP_API_URL="$2"; shift 2 ;;
      --db-host)         [[ $# -ge 2 ]] || die "--db-host needs a value"; SETUP_DB_HOST="$2"; shift 2 ;;
      --minio)           [[ $# -ge 2 ]] || die "--minio needs a value"; SETUP_MINIO="$2"; shift 2 ;;
      --edge)            mode="edge"; shift ;;
      --host)            [[ $# -ge 2 ]] || die "--host needs a value"; EDGE_HOST="$2"; shift 2 ;;
      --ui)              [[ $# -ge 2 ]] || die "--ui needs a value"; EDGE_UI="$2"; shift 2 ;;
      --api)             [[ $# -ge 2 ]] || die "--api needs a value"; EDGE_API="$2"; shift 2 ;;
      --cert)            [[ $# -ge 2 ]] || die "--cert needs a value"; EDGE_CERT="$2"; shift 2 ;;
      --key)             [[ $# -ge 2 ]] || die "--key needs a value"; EDGE_KEY="$2"; shift 2 ;;
      --no-reload)       EDGE_NO_RELOAD=1; shift ;;
      --remote-db)
        mode="remote-db"
        if [[ $# -ge 2 && "$2" != --* ]]; then remote_db_val="$2"; shift 2; else shift; fi
        ;;
      --remote-api)
        mode="remote-api"
        if [[ $# -ge 2 && "$2" != --* ]]; then remote_api_val="$2"; shift 2; else shift; fi
        ;;
      --self-update)     mode="self-update"; shift ;;
      --recover|--doctor) mode="recover"; shift ;;
      --fresh-start)     mode="fresh-start"; shift ;;
      --service)
        [[ $# -ge 2 ]] || die "--service requires a value (api|ui|test|demo|all)"
        service_arg="$2"; shift 2 ;;
      --service=*)       service_arg="${1#*=}"; shift ;;
      --allow-destructive) ALLOW_DESTRUCTIVE=true; shift ;;
      -*)                die "Unknown option: $1 (try --help)" ;;
      *)
        if [[ -n "$positional" ]]; then
          die "Unexpected extra argument: $1"
        fi
        positional="$1"; shift ;;
    esac
  done

  case "$mode" in
    list)
      preflight
      cmd_list "$list_mode"
      ;;
    status)
      preflight
      cmd_status
      ;;
    rollback)
      preflight
      if [[ -n "$service_arg" ]]; then
        cmd_rollback "$service_arg"
      else
        cmd_rollback all
      fi
      ;;
    logs)
      cmd_logs
      ;;
    components)
      cmd_components "$components_val"
      ;;
    wizard)
      cmd_wizard
      ;;
    up)
      cmd_up
      ;;
    setup)
      cmd_setup
      ;;
    edge)
      cmd_edge
      ;;
    remote-db)
      cmd_remote_db "$remote_db_val" "$SETUP_MINIO"
      ;;
    remote-api)
      cmd_remote_api "$remote_api_val"
      ;;
    self-update)
      cmd_self_update
      ;;
    recover)
      # Deliberately NO preflight — broken/incomplete states are the point.
      RECOVERY_ENTRY="forge-deploy --recover"
      cmd_recover
      ;;
    fresh-start)
      RECOVERY_ENTRY="forge-deploy --fresh-start"
      cmd_fresh_start
      ;;
    "")
      # No mode flag — deploy.
      preflight
      local services
      if [[ -n "$service_arg" ]]; then
        mapfile -t services < <(parse_service_arg "$service_arg")
      else
        mapfile -t services < <(box_service_ids)
      fi
      EXPLICIT_TAG="$positional"
      cmd_deploy "${services[@]}"
      ;;
    *)
      die "Internal error: unhandled mode '$mode'"
      ;;
  esac
}

main "$@"
