# Operator-managed files — created by setup.sh / forge-deploy on each install.
# Tracking these caused a recurring "forge-deploy --self-update refuses to pull"
# papercut on the Pi (git status --porcelain flagged them as dirty).
.env
docker-compose.override.yml
docker-compose.scope.yml
docker-compose.remote-api.yml
forge-api-proxy.conf
setup-public-rollback.sh

# Operator-managed runtime data (bind-mount targets).
storage/
keys/
backups/

# Build artifacts — .NET (tools/rfid-relay/pcsc-relay) + future projects.
bin/
obj/

# Node — tools/rfid-relay
node_modules/

# Audit/analysis probe scratch dropped in tools/ (regenerable; not deploy tooling).
tools/*.csx
tools/*.sql

# OS junk
.DS_Store
Thumbs.db
