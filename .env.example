# qb-engineer .env — copy this to `.env` (setup.sh does that automatically).
#
# Values shown are dev defaults. Production hosts (Pi) tighten these via
# setup.sh + qb-deploy. See docs/cicd-design.md for the full picture.

# ─────────────────────────────────────────────────────────────
# Hosting mode
# ─────────────────────────────────────────────────────────────

# standalone | cohost — see docker-compose.cohost.yml + docs/cohosting.md
QBE_HOSTING_MODE=standalone

# ─────────────────────────────────────────────────────────────
# Image tags (managed by qb-deploy on the Pi — DO NOT hand-edit in prod)
# ─────────────────────────────────────────────────────────────
#
# qb-deploy refuses to deploy `latest` to production: deployments must
# pin to an immutable tag (main-<sha> or X.Y.Z). The defaults below are
# only used in dev where docker-compose.prod.yml is not loaded.

SERVER_IMAGE_TAG=latest
UI_IMAGE_TAG=latest
TEST_IMAGE_TAG=latest

# ─────────────────────────────────────────────────────────────
# Network / ports
# ─────────────────────────────────────────────────────────────

UI_BIND=127.0.0.1
UI_PORT=4200
API_BIND=127.0.0.1
API_PORT=5000
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
MINIO_BIND=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AI_BIND=127.0.0.1
AI_PORT=11434
TTS_BIND=127.0.0.1
TTS_PORT=5002
DOCUSEAL_BIND=127.0.0.1
DOCUSEAL_PORT=3000

# ─────────────────────────────────────────────────────────────
# .NET runtime
# ─────────────────────────────────────────────────────────────

ASPNETCORE_ENVIRONMENT=Development
RECREATE_DB=false
SEED_DEMO_DATA=true
SEED_USER_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

POSTGRES_DB=qb_engineer
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─────────────────────────────────────────────────────────────
# Auth (JWT)
# ─────────────────────────────────────────────────────────────

JWT_KEY=dev-secret-key-change-in-production-min-32-chars!!
JWT_ISSUER=qb-engineer
JWT_AUDIENCE=qb-engineer-ui

# ─────────────────────────────────────────────────────────────
# CORS / public URLs
# ─────────────────────────────────────────────────────────────

FRONTEND_BASE_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200
FORM_RENDERER_BASE_URL=http://qb-engineer-ui:80

# ─────────────────────────────────────────────────────────────
# Storage (MinIO + local)
# ─────────────────────────────────────────────────────────────

STORAGE_PROVIDER=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PUBLIC_ENDPOINT=localhost:9000
LOCAL_STORAGE_PATH=./storage
LOCAL_STORAGE_PUBLIC_URL=http://localhost:5000
LOCAL_STORAGE_URL_EXPIRY=3600

# ─────────────────────────────────────────────────────────────
# Integrations (mock by default in dev)
# ─────────────────────────────────────────────────────────────

MOCK_INTEGRATIONS=true
USPS_CONSUMER_KEY=
USPS_CONSUMER_SECRET=
STAMPS_API_KEY=
STAMPS_ACCOUNT_ID=
STAMPS_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────────────
# AI (Ollama, optional profile)
# ─────────────────────────────────────────────────────────────

AI_BASE_URL=http://qb-engineer-ai:11434
AI_MODEL=gemma3:4b
AI_EMBEDDING_MODEL=all-minilm:l6-v2

# ─────────────────────────────────────────────────────────────
# DocuSeal (optional profile)
# ─────────────────────────────────────────────────────────────

DOCUSEAL_BASE_URL=http://qb-engineer-signing:3000
DOCUSEAL_PUBLIC_BASE_URL=
DOCUSEAL_API_KEY=
DOCUSEAL_TIMEOUT=30
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_SECRET_KEY=change-me-in-production

# ─────────────────────────────────────────────────────────────
# TTS / Coqui (optional profile)
# ─────────────────────────────────────────────────────────────

TTS_API_KEY=
COQUI_BASE_URL=
COQUI_SPEAKER_ID=

# ─────────────────────────────────────────────────────────────
# Logging (Seq, optional profile)
# ─────────────────────────────────────────────────────────────

SEQ_SERVER_URL=
SEQ_API_KEY=
SEQ_ADMIN_USERNAME=admin
SEQ_ADMIN_PASSWORD_HASH=

# ─────────────────────────────────────────────────────────────
# Build metadata (set by CI in prod images)
# ─────────────────────────────────────────────────────────────

BUILD_VERSION=0
BUILD_SHA=dev
APP_VERSION=dev
GIT_COMMIT=
