# forge .env — copy this to `.env` (setup.sh does that automatically).
#
# Values shown are dev defaults. Production hosts (Pi) tighten these via
# setup.sh + forge-deploy. See docs/cicd-design.md for the full picture.

# ─────────────────────────────────────────────────────────────
# Hosting mode
# ─────────────────────────────────────────────────────────────

# standalone | cohost — see docker-compose.cohost.yml + docs/cohosting.md
QBE_HOSTING_MODE=standalone

# ─────────────────────────────────────────────────────────────
# Image tags (managed by forge-deploy on the Pi — DO NOT hand-edit in prod)
# ─────────────────────────────────────────────────────────────
#
# forge-deploy refuses to deploy `latest` to production: deployments must
# pin to an immutable tag (main-<sha> or X.Y.Z). The defaults below are
# only used in dev where docker-compose.prod.yml is not loaded.

SERVER_IMAGE_TAG=latest
UI_IMAGE_TAG=latest
TEST_IMAGE_TAG=latest

# Seconds forge-deploy waits for a service to report healthy before rolling
# back. forge-api applies EF Core migrations and warms its composite health
# check (Postgres + Hangfire + MinIO + SignalR) before /api/v1/health returns
# 200, so a clean deploy against a populated DB can exceed the 180s default.
# Raise this on slower hosts / larger databases. Leave unset to use 180.
#HEALTHCHECK_TIMEOUT_SECS=180

# ─────────────────────────────────────────────────────────────
# Network / ports
# ─────────────────────────────────────────────────────────────

UI_BIND=127.0.0.1
UI_PORT=4200
API_BIND=127.0.0.1
API_PORT=5000
TEST_BIND=127.0.0.1
TEST_PORT=4300
POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432
MINIO_BIND=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
AI_BIND=127.0.0.1
AI_PORT=11434
TTS_BIND=127.0.0.1
TTS_PORT=5002
DOCUSEAL_BIND=127.0.0.1
DOCUSEAL_PORT=3000

# ─────────────────────────────────────────────────────────────
# .NET runtime
# ─────────────────────────────────────────────────────────────

ASPNETCORE_ENVIRONMENT=Development
RECREATE_DB=false
SEED_DEMO_DATA=true
SEED_USER_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

POSTGRES_DB=forge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─────────────────────────────────────────────────────────────
# Auth (JWT)
# ─────────────────────────────────────────────────────────────

JWT_KEY=dev-secret-key-change-in-production-min-32-chars!!
JWT_ISSUER=forge
JWT_AUDIENCE=forge-ui

# ─────────────────────────────────────────────────────────────
# SSO (Google) — browser sign-in + federated token-exchange
# ─────────────────────────────────────────────────────────────
# Enables "Sign in with Google" on the login page AND the
# /api/v1/auth/sso/token-exchange endpoint used by federated apps
# (e.g. Tuyere) to trade a Google id_token for a Forge JWT.
#
# For the browser flow, register this redirect URI on the OAuth client
# in Google Cloud Console:
#   https://<your-forge-host>/api/v1/auth/sso/google/callback
#
# A federated app sharing the SAME OAuth client needs no extra config —
# its id_token audience already matches SSO_GOOGLE_CLIENT_ID. If it uses
# its OWN client, add that client id via Sso__Google__AdditionalAudiences__0
# in a docker-compose.override.yml.
#
# Optional email-domain allow-list: add to docker-compose.override.yml
#   - Sso__Google__AllowedDomains__0=example.com
# Do NOT wire it to an env var that can be empty — a present-but-empty
# entry binds as [""] and rejects EVERY sign-in.

SSO_GOOGLE_ENABLED=false
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────
# CORS / public URLs
# ─────────────────────────────────────────────────────────────

FRONTEND_BASE_URL=http://localhost:4200

# CORS_ORIGINS appends to a hardcoded list of localhost variants in the api.
# For production deploys behind a public hostname (Cloudflare Tunnel, reverse
# proxy, etc.), add every public origin a browser will use here — including
# `www.` variants and any subdomain you serve. SignalR's negotiate uses the
# Origin header even on same-host paths, so a missing entry here surfaces as
# "CORS policy execution failed" log lines and broken real-time features.
# Comma-separated; no spaces; include scheme.
# Production example:
#   CORS_ORIGINS=https://forge.com,https://www.forge.com,https://test-scripts.forge.com
CORS_ORIGINS=http://localhost:4200

FORM_RENDERER_BASE_URL=http://forge-ui:80

# ─────────────────────────────────────────────────────────────
# Storage (MinIO + local)
# ─────────────────────────────────────────────────────────────

STORAGE_PROVIDER=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PUBLIC_ENDPOINT=localhost:9000
LOCAL_STORAGE_PATH=./storage
LOCAL_STORAGE_PUBLIC_URL=http://localhost:5000
LOCAL_STORAGE_URL_EXPIRY=3600

# ─────────────────────────────────────────────────────────────
# Backups (forge-backup container — pg_dump + MinIO mirror)
# ─────────────────────────────────────────────────────────────
#
# Snapshots land under ./backups/<UTC-timestamp>/. v1 is local-volume
# only; S3 / SFTP destinations follow once the admin-configurable
# version ships. See docs/backup-restore.md for the restore procedure.

# Cron expression (UTC). Default: daily at 2am.
BACKUP_SCHEDULE=0 2 * * *

# Delete snapshot directories older than this many days.
BACKUP_RETENTION_DAYS=30

# Run an immediate backup at container start (useful on first install /
# after restore). Leave false in steady state.
BACKUP_RUN_ON_START=false

# ─────────────────────────────────────────────────────────────
# Integrations (mock by default in dev)
# ─────────────────────────────────────────────────────────────

MOCK_INTEGRATIONS=true
USPS_CONSUMER_KEY=
USPS_CONSUMER_SECRET=
STAMPS_API_KEY=
STAMPS_ACCOUNT_ID=
STAMPS_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────────────
# AI (Ollama, optional profile)
# ─────────────────────────────────────────────────────────────

AI_BASE_URL=http://forge-ai:11434
AI_MODEL=gemma3:4b
AI_EMBEDDING_MODEL=all-minilm:l6-v2

# ─────────────────────────────────────────────────────────────
# DocuSeal (optional profile)
# ─────────────────────────────────────────────────────────────

DOCUSEAL_BASE_URL=http://forge-signing:3000
DOCUSEAL_PUBLIC_BASE_URL=
DOCUSEAL_API_KEY=
DOCUSEAL_TIMEOUT=30
DOCUSEAL_WEBHOOK_SECRET=
DOCUSEAL_SECRET_KEY=change-me-in-production

# ─────────────────────────────────────────────────────────────
# TTS / Coqui (optional profile)
# ─────────────────────────────────────────────────────────────

TTS_API_KEY=
COQUI_BASE_URL=
COQUI_SPEAKER_ID=

# ─────────────────────────────────────────────────────────────
# Logging (Seq, optional profile)
# ─────────────────────────────────────────────────────────────

SEQ_SERVER_URL=
SEQ_API_KEY=
SEQ_ADMIN_USERNAME=admin
SEQ_ADMIN_PASSWORD_HASH=

# ─────────────────────────────────────────────────────────────
# Build metadata (set by CI in prod images)
# ─────────────────────────────────────────────────────────────

BUILD_VERSION=0
BUILD_SHA=dev
APP_VERSION=dev
GIT_COMMIT=
